#!/usr/bin/env ruby
# frozen_string_literal: true

# This script runs the Solid Queue worker locally for development
# Only needed if using :solid_queue adapter (set RAILS_QUEUE_ADAPTER=solid_queue)
# With :async adapter (default), jobs run automatically - no worker needed

require_relative "../config/environment"

puts "Starting Solid Queue worker..."
puts "Environment: #{Rails.env}"
puts "Queue adapter: #{Rails.application.config.active_job.queue_adapter}"
puts "Press Ctrl+C to stop"

# Ensure Solid Queue is configured
Rails.application.config.active_job.queue_adapter ||= :solid_queue

# Start Solid Queue supervisor
require "solid_queue"

# Load Solid Queue configuration
SolidQueue::Supervisor.start