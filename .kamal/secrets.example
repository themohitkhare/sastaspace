# Kamal Secrets File
# Copy this file to .kamal/secrets and fill in the actual values
# DO NOT commit .kamal/secrets to git

# Docker Hub credentials
# Get your access token from: https://hub.docker.com/settings/security
KAMAL_REGISTRY_USERNAME=your_dockerhub_username
KAMAL_REGISTRY_PASSWORD=your_dockerhub_password_or_token

# Rails master key (from config/master.key)
RAILS_MASTER_KEY=your_rails_master_key_here

# PostgreSQL password for the database accessory
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Database URLs - Replace with your actual credentials
# IMPORTANT: Special characters need URL encoding in URLs
# Example: ! becomes %21, @ becomes %40, # becomes %23
DATABASE_URL=postgresql://sastaspace_admin:YOUR_PASSWORD_URL_ENCODED@sastaspace-db:5432/sastaspace_production
CACHE_DATABASE_URL=postgresql://sastaspace_admin:YOUR_PASSWORD_URL_ENCODED@sastaspace-db:5432/sastaspace_production_cache
QUEUE_DATABASE_URL=postgresql://sastaspace_admin:YOUR_PASSWORD_URL_ENCODED@sastaspace-db:5432/sastaspace_production_queue
CABLE_DATABASE_URL=postgresql://sastaspace_admin:YOUR_PASSWORD_URL_ENCODED@sastaspace-db:5432/sastaspace_production_cable

