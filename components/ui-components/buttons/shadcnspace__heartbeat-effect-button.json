      "content": "import { Button } from \"@/components/ui/button\";\n\n\nconst ButtonHeartbeatEffectDemo = () => {\n  return (\n    <>\n      <Button variant=\"destructive\" className=\"heartbeateffect cursor-pointer\">\n        Heartbeat Effect\n      </Button>\n    </>\n  );\n};\n\nexport default ButtonHeartbeatEffectDemo;\n",
