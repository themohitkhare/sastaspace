      "content": "import { Sun, Moon, Settings } from 'lucide-react';\n\nexport const Component = () => {\n\n  return (\n    <div\n      className=\"\n        inline-flex rounded-lg overflow-hidden relative\n        bg-white/20 dark:bg-black/40\n        backdrop-blur-md\n        shadow-lg shadow-black/20\n        border border-gray-300 dark:border-black/60\n        transition-colors duration-500\n      \"\n    >\n      <button\n        className=\"\n          px-4 py-2 rounded-l-lg\n          flex items-center gap-2\n          text-black dark:text-white\n          bg-transparent\n          hover:bg-black/10 dark:hover:bg-white/10\n          transition-colors duration-300\n          focus:outline-none focus:ring-0\n          border-r border-gray-300 dark:border-black/60\n          group\n        \"\n        aria-label=\"Toggle Light Mode\"\n      >\n        <Sun\n          className=\"\n            w-5 h-5\n            text-current\n            transition-transform duration-300\n            group-hover:scale-110\n          \"\n          aria-hidden=\"true\"\n        />\n        <span className=\"select-none\">Light</span>\n      </button>\n\n      <button\n        className=\"\n          px-4 py-2\n          flex items-center gap-2\n          text-black dark:text-white\n          bg-transparent\n          hover:bg-black/10 dark:hover:bg-white/10\n          transition-colors duration-300\n          focus:outline-none focus:ring-0\n          border-r border-gray-300 dark:border-black/60\n          group\n        \"\n        aria-label=\"Toggle Dark Mode\"\n      >\n        <Moon\n          className=\"\n            w-5 h-5\n            text-current\n            transition-transform duration-300\n            group-hover:scale-110\n          \"\n          aria-hidden=\"true\"\n        />\n        <span className=\"select-none\">Dark</span>\n      </button>\n\n      <button\n        className=\"\n          px-4 py-2 rounded-r-lg\n          flex items-center gap-2\n          text-black dark:text-white\n          bg-transparent\n          hover:bg-black/10 dark:hover:bg-white/10\n          transition-colors duration-300\n          focus:outline-none focus:ring-0\n          group\n        \"\n        aria-label=\"Open Settings\"\n      >\n        <Settings\n          className=\"\n            w-5 h-5\n            text-current\n            transition-transform duration-300\n            group-hover:scale-110\n          \"\n          aria-hidden=\"true\"\n        />\n        <span className=\"select-none\">Settings</span>\n      </button>\n    </div>\n  );\n};\n",
