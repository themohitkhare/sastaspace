# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.jks
infra/k8s/secrets.yaml
.last-image-tag

# Dependencies
node_modules/

# JavaScript / TypeScript build outputs
.next/
out/
dist/
coverage/
*.tsbuildinfo

# Go build outputs (scoped to per-project api/ subdirs so Rails bin/ dirs aren't hidden)
projects/*/api/bin/
*.test
*.out

# General runtime/cache
*.log
tmp/
.cache/
.DS_Store

# Ruby / Rails per-project artifacts
projects/*/vendor/bundle/
projects/*/.bundle/
projects/*/log/
projects/*/tmp/
projects/*/storage/
projects/*/public/assets/
projects/*/app/assets/builds/*
!projects/*/app/assets/builds/.keep
projects/*/config/master.key

# Docker/local artifacts
*.pid
.playwright-mcp/

# Ruflo / claude-flow MCP artifacts (do not commit)
.claude-flow/
.swarm/
ruvector.db
.mcp.json

