# ---- Postgres ------------------------------------------------------------
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=sastaspace
POSTGRES_USER=postgres

# ---- JWT / Supabase keys -------------------------------------------------
# Run `make keys` to fill these in. JWT_SECRET must be >= 32 chars, and
# ANON_KEY / SERVICE_ROLE_KEY must be signed with it.
JWT_SECRET=replace-with-long-random-string-min-32-chars
ANON_KEY=replace-with-signed-anon-jwt
SERVICE_ROLE_KEY=replace-with-signed-service-role-jwt

# ---- GoTrue (auth) -------------------------------------------------------
# API_EXTERNAL_URL is what gotrue bakes into confirmation emails + OAuth
# redirects, so it must be the URL the *browser* will hit — i.e. the gateway
# at /auth/v1, not gotrue directly.
GOTRUE_API_EXTERNAL_URL=http://localhost:8000/auth/v1
GOTRUE_SITE_URL=http://localhost:3000
GOTRUE_URI_ALLOW_LIST=http://localhost:3000,http://localhost:8000,https://sastaspace.com,https://*.sastaspace.com
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_SMTP_HOST=smtp.resend.com
GOTRUE_SMTP_PORT=465
GOTRUE_SMTP_USER=resend
GOTRUE_SMTP_PASS=re_replace_me
GOTRUE_SMTP_ADMIN_EMAIL=noreply@sastaspace.com
GOTRUE_SMTP_SENDER_NAME=SastaSpace

GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=http://localhost:9999/callback

GOTRUE_EXTERNAL_GITHUB_ENABLED=false
GOTRUE_EXTERNAL_GITHUB_CLIENT_ID=
GOTRUE_EXTERNAL_GITHUB_SECRET=
GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI=http://localhost:9999/callback

# ---- Next.js (client + server) -------------------------------------------
# Browsers + supabase-js talk to the gateway, which routes /auth/v1/* to
# gotrue and /rest/v1/* to postgrest.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-signed-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=replace-with-signed-service-role-jwt

NEXT_PUBLIC_BASE_URL=https://sastaspace.com
# Used as the `NEXT_PUBLIC_BASE_URL` when landing is built via --profile full.
NEXT_PUBLIC_BASE_URL_LOCAL=http://localhost:3000

# ---- Contact form --------------------------------------------------------
RESEND_API_KEY=re_replace_me
OWNER_EMAIL=mohitkhare582@gmail.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace_me
TURNSTILE_SECRET_KEY=replace_me

# ---- Ports (host-side mappings) ------------------------------------------
POSTGRES_PORT=5432
POSTGREST_PORT=3001
GOTRUE_PORT=9999
STUDIO_PORT=3002
PG_META_PORT=8080
LANDING_PORT=3000
GATEWAY_PORT=8000

# ---- Remote deploy (ssh 192.168.0.37) ------------------------------------
# `make remote-*` targets rsync + ssh to this host. Leave blank if unused.
SSH_HOST=192.168.0.37
SSH_REMOTE_DIR=~/sastaspace
# Host/IP the browser will use to reach services on the remote box. Used by
# `scripts/remote.sh env` to bootstrap a remote .env. Defaults to the host
# part of SSH_HOST when unset.
REMOTE_HOST=192.168.0.37
