# Backend URL — set in development so the iframe preview points to FastAPI (port 8080)
# In production, leave unset (the reverse proxy handles routing /{subdomain}/ → backend)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Contact form — Resend email delivery
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OWNER_EMAIL=owner@example.com

# Contact form — Cloudflare Turnstile (invisible mode)
# For development, use test keys:
#   Site key: 1x00000000000000000000AA (always passes)
#   Secret key: 1x0000000000000000000000000000000AA (always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
