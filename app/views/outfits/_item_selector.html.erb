<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
  <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Your Wardrobe</h2>
  
  <!-- Search -->
  <div class="mb-4">
    <input 
      type="text" 
      placeholder="Search items..." 
      class="form-input w-full"
      data-outfit-builder-target="searchInput"
      data-action="input->outfit-builder#searchItems"
    />
  </div>

  <!-- Category Tabs -->
  <div class="flex flex-wrap gap-2 mb-6" data-outfit-builder-target="categoryTabs">
    <button 
      type="button"
      class="px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-medium transition-colors"
      data-category-id="all"
      data-action="click->outfit-builder#filterByCategory"
    >
      All Items
    </button>
    <% Category.root_categories.active.ordered.limit(8).each do |category| %>
      <button 
        type="button"
        class="px-4 py-2 rounded-lg bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300 text-sm font-medium hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors"
        data-category-id="<%= category.id %>"
        data-action="click->outfit-builder#filterByCategory"
      >
        <%= category.name %>
      </button>
    <% end %>
  </div>

  <!-- Items Grid -->
  <div 
    class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4"
    data-outfit-builder-target="itemsGrid"
  >
    <!-- Items will be loaded dynamically -->
    <div class="col-span-full text-center py-8 text-gray-500">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
      <p class="mt-2">Loading items...</p>
    </div>
  </div>
</div>

