<div class="bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-lg transition-shadow overflow-hidden">
  <%= link_to outfit_path(outfit), class: "block" do %>
    <!-- Outfit Image Preview or Placeholder -->
    <div class="relative h-48 bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
      <% if outfit.inventory_items.any? && outfit.inventory_items.first.primary_image.attached? %>
        <%= image_tag outfit.inventory_items.first.primary_image.variant(resize_to_limit: [400, 400]), 
            alt: outfit.name,
            class: "w-full h-full object-cover" %>
      <% else %>
        <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      <% end %>
      
      <!-- Favorite Badge -->
      <% if outfit.is_favorite? %>
        <div class="absolute top-2 right-2">
          <span class="text-yellow-400">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </span>
        </div>
      <% end %>
    </div>

    <!-- Outfit Info -->
    <div class="p-4">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1 truncate">
        <%= outfit.name %>
      </h3>
      
      <% if outfit.description.present? %>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-2 line-clamp-2">
          <%= outfit.description %>
        </p>
      <% end %>

      <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
        <div class="flex items-center space-x-3">
          <% if outfit.occasion.present? %>
            <span class="px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded">
              <%= outfit.occasion.capitalize %>
            </span>
          <% end %>
          <span><%= pluralize(outfit.inventory_items.count, 'item') %></span>
        </div>
        <span><%= outfit.created_at.strftime("%b %d, %Y") %></span>
      </div>
    </div>
  <% end %>
</div>
