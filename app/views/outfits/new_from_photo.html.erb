<div data-controller="outfit-photo-analyzer" class="max-w-6xl mx-auto p-6">
  <div class="card">
    <div class="card-header">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Create Outfit from Photo</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Upload a photo of an outfit and AI will extract individual items for you</p>
    </div>

    <div class="card-body space-y-6">
      <!-- Step 1: Upload Outfit Photo -->
      <div data-outfit-photo-analyzer-target="uploadStep" class="space-y-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Step 1: Upload Outfit Photo</h2>
        
        <!-- Image Upload Area -->
        <div 
          data-outfit-photo-analyzer-target="uploadArea"
          class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-8 text-center hover:border-primary-500 dark:hover:border-primary-400 transition-colors cursor-pointer"
          data-action="click->outfit-photo-analyzer#triggerFileInput dragover->outfit-photo-analyzer#handleDragOver drop->outfit-photo-analyzer#handleDrop"
        >
          <input
            type="file"
            accept="image/*"
            data-outfit-photo-analyzer-target="fileInput"
            data-action="change->outfit-photo-analyzer#handleFileSelect"
            class="hidden"
          />
          
          <div data-outfit-photo-analyzer-target="uploadPrompt">
            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
              <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
              <span class="font-semibold">Click to upload</span> or drag and drop
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-500 mt-1">PNG, JPG, WebP up to 5MB</p>
          </div>

          <!-- Image Preview -->
          <div data-outfit-photo-analyzer-target="imagePreview" class="hidden">
            <img data-outfit-photo-analyzer-target="previewImage" src="" alt="Preview" class="max-h-96 mx-auto rounded-lg" />
            <p data-outfit-photo-analyzer-target="previewName" class="mt-2 text-sm text-gray-600 dark:text-gray-400"></p>
          </div>
        </div>

        <!-- Loading State -->
        <div data-outfit-photo-analyzer-target="loadingState" class="hidden">
          <div class="flex items-center justify-center p-8">
            <div class="text-center">
              <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600"></div>
              <p class="mt-4 text-gray-700 dark:text-gray-300">Analyzing your outfit photo...</p>
              <p class="mt-2 text-sm text-gray-500 dark:text-gray-500">This may take a few moments</p>
              <p data-outfit-photo-analyzer-target="analysisProgress" class="mt-2 text-xs text-gray-400"></p>
            </div>
          </div>
        </div>

        <!-- Error State -->
        <div data-outfit-photo-analyzer-target="errorState" class="hidden p-4 bg-red-50 border border-red-200 text-red-800 rounded dark:bg-red-900 dark:border-red-700 dark:text-red-200">
          <p data-outfit-photo-analyzer-target="errorMessage"></p>
          <button
            type="button"
            data-action="click->outfit-photo-analyzer#retryAnalysis"
            class="mt-2 text-sm underline"
          >
            Try again
          </button>
        </div>
      </div>

      <!-- Step 2: Review Detected Items -->
      <div data-outfit-photo-analyzer-target="reviewStep" class="hidden space-y-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Step 2: Review Detected Items</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
          Review the items AI detected from your outfit photo. Edit any details before creating them.
        </p>

        <!-- Items Grid -->
        <div data-outfit-photo-analyzer-target="itemsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <!-- Items will be dynamically inserted here -->
        </div>

        <!-- Action Buttons -->
        <div class="flex justify-end gap-3 pt-6 border-t border-gray-200 dark:border-gray-700">
          <button
            type="button"
            data-action="click->outfit-photo-analyzer#cancelReview"
            class="btn-secondary"
          >
            Cancel
          </button>
          <button
            type="button"
            data-action="click->outfit-photo-analyzer#createItems"
            data-outfit-photo-analyzer-target="createButton"
            class="btn-primary"
          >
            Create Items
          </button>
        </div>
      </div>

      <!-- Step 3: Create Outfit -->
      <div data-outfit-photo-analyzer-target="outfitStep" class="hidden space-y-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Step 3: Create Outfit</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
          Items created! Now create an outfit with these items.
        </p>

        <div data-outfit-photo-analyzer-target="createdItemsInfo" class="p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
          <!-- Created items info will be shown here -->
        </div>

        <div class="flex justify-end gap-3 pt-6">
          <a href="<%= outfits_path %>" class="btn-secondary">Skip</a>
          <a href="<%= builder_outfits_path %>" data-outfit-photo-analyzer-target="builderLink" class="btn-primary">
            Open Outfit Builder
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

