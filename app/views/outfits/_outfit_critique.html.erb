<div data-controller="outfit-critique" data-outfit-critique-outfit-id-value="<%= outfit.id %>" class="mt-8">
  <div class="flex justify-center mb-6">
    <button 
      data-action="click->outfit-critique#analyze"
      data-outfit-critique-target="button"
      class="bg-gradient-to-r from-purple-600 to-blue-600 text-white px-6 py-3 rounded-full font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 flex items-center gap-2"
    >
      <span class="text-xl">✨</span>
      Ask AI Stylist
    </button>
  </div>

  <div data-outfit-critique-target="loading" class="hidden text-center py-8">
    <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-purple-200 border-t-purple-600 mb-2"></div>
    <p class="text-gray-500 font-medium animate-pulse">Analyzing your style...</p>
  </div>

  <div data-outfit-critique-target="content" class="hidden animate-fade-in-up">
    <div data-outfit-critique-target="results">
      <!-- Results injected here -->
    </div>
  </div>
</div>

