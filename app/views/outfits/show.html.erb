<div class="p-6">
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2"><%= @outfit.name %></h1>
        <% if @outfit.description.present? %>
          <p class="text-lg text-gray-600 dark:text-gray-400"><%= @outfit.description %></p>
        <% end %>
      </div>
      <div class="flex items-center space-x-4">
        <% if @outfit.is_favorite? %>
          <span class="text-yellow-400" title="Favorite">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </span>
        <% end %>
        <%= link_to "Edit", edit_outfit_path(@outfit), class: "btn-secondary" %>
      </div>
    </div>
    
    <div class="mt-4 flex items-center space-x-4 text-sm text-gray-500 dark:text-gray-400">
      <% if @outfit.occasion.present? %>
        <span class="px-3 py-1 bg-gray-100 dark:bg-gray-700 rounded-full">
          <%= @outfit.occasion.capitalize %>
        </span>
      <% end %>
      <span>Created <%= time_ago_in_words(@outfit.created_at) %> ago</span>
    </div>
  </div>

  <!-- AI Stylist Critique -->
  <%= render partial: "outfit_critique", locals: { outfit: @outfit } %>

  <!-- Outfit Items -->
  <% if @outfit.inventory_items.any? %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">
        Items (<%= @outfit.inventory_items.count %>)
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <% @outfit.inventory_items.each do |item| %>
          <div class="border rounded-lg p-3 bg-white dark:bg-gray-700 hover:shadow-md transition-shadow">
            <%= link_to inventory_item_path(item), class: "block" do %>
              <% if item.primary_image.attached? %>
                <%= image_tag item.primary_image.variant(resize_to_limit: [200, 200]), 
                    alt: item.name,
                    class: "w-full h-32 object-cover rounded mb-2" %>
              <% else %>
                <div class="w-full h-32 bg-gray-200 dark:bg-gray-600 rounded mb-2 flex items-center justify-center">
                  <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              <% end %>
              <h3 class="text-sm font-medium text-gray-900 dark:text-white truncate"><%= item.name %></h3>
              <p class="text-xs text-gray-500 dark:text-gray-400">
                <%= item.category&.name || "Uncategorized" %>
              </p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-8 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
      </svg>
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No items in this outfit</h3>
      <p class="text-gray-500 dark:text-gray-400 mb-4">Add items to complete your outfit</p>
      <%= link_to "Edit Outfit", edit_outfit_path(@outfit), class: "btn-primary inline-block" %>
    </div>
  <% end %>

  <!-- Actions -->
  <div class="flex items-center justify-between pt-4 border-t border-gray-200 dark:border-gray-700">
    <%= link_to "← Back to Outfits", outfits_path, class: "text-primary-600 dark:text-primary-400 hover:underline" %>
    <div class="flex space-x-2">
      <%= link_to "Delete", outfit_path(@outfit), 
          data: { 
            turbo_method: :delete,
            turbo_confirm: "Are you sure you want to delete this outfit?"
          },
          class: "btn-secondary text-red-600 hover:text-red-700" %>
    </div>
  </div>
</div>
