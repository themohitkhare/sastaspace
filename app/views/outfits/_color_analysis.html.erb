<div 
  class="bg-white dark:bg-gray-800 rounded-lg shadow p-6" 
  data-controller="color-analysis"
  data-color-analysis-user-id-value="<%= current_user.id %>"
>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center gap-2">
      <span class="text-xl">🎨</span> Color Analysis
    </h2>
    <div data-color-analysis-target="scoreBadge" class="hidden px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300">
      --%
    </div>
  </div>

  <div data-color-analysis-target="content" class="min-h-[100px]">
    <!-- Initial State -->
    <div class="text-center py-6 text-gray-500 dark:text-gray-400">
      <p class="text-sm">Add items to see color coordination analysis</p>
    </div>
  </div>

  <!-- Loading State -->
  <div data-color-analysis-target="loading" class="hidden">
    <div class="flex items-center justify-center py-6 space-x-2 text-gray-500">
      <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-primary-600"></div>
      <span class="text-sm">Analyzing colors...</span>
    </div>
  </div>

  <!-- Template for Analysis Results (used by controller) -->
  <template data-color-analysis-target="resultTemplate">
    <div class="space-y-4 animate-fade-in">
      <!-- Score Bar -->
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="font-medium text-gray-700 dark:text-gray-300">Coordination Score</span>
          <span class="font-bold" data-field="scoreValue">0%</span>
        </div>
        <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2.5 overflow-hidden">
          <div data-field="scoreBar" class="bg-primary-600 h-2.5 rounded-full transition-all duration-500" style="width: 0%"></div>
        </div>
      </div>

      <!-- Color Palette -->
      <div>
        <p class="text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">Outfit Palette</p>
        <div data-field="palette" class="flex flex-wrap gap-2">
          <!-- Color chips injected here -->
        </div>
      </div>

      <!-- Feedback -->
      <div class="bg-gray-50 dark:bg-gray-700/50 rounded p-3 border border-gray-100 dark:border-gray-700">
        <div class="flex items-start gap-2">
          <span class="text-lg mt-0.5">💡</span>
          <div>
            <p data-field="feedback" class="text-sm font-medium text-gray-900 dark:text-white"></p>
            <ul data-field="suggestions" class="mt-1 space-y-1">
              <!-- Suggestions injected here -->
            </ul>
          </div>
        </div>
      </div>

      <!-- Warnings -->
      <div data-field="warningsContainer" class="hidden bg-yellow-50 dark:bg-yellow-900/20 rounded p-3 border border-yellow-100 dark:border-yellow-900/30">
        <div class="flex items-start gap-2">
          <span class="text-lg mt-0.5">⚠️</span>
          <ul data-field="warnings" class="text-sm text-yellow-800 dark:text-yellow-200 space-y-1">
            <!-- Warnings injected here -->
          </ul>
        </div>
      </div>
    </div>
  </template>
</div>

