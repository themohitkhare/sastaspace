<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6" data-controller="ai-suggestions" data-ai-suggestions-outfit-id-value="<%= local_assigns[:outfit_id] || '' %>">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center space-x-2">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white">AI Suggestions</h2>
      <span class="px-2 py-0.5 text-xs font-medium bg-primary-100 text-primary-800 dark:bg-primary-900 dark:text-primary-200 rounded-full">Beta</span>
    </div>
    <button 
      type="button" 
      data-action="click->ai-suggestions#regenerate"
      class="text-sm text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 flex items-center space-x-1 transition-colors"
      data-ai-suggestions-target="regenerateButton"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
      <span>Regenerate</span>
    </button>
  </div>
  
  <!-- Filters -->
  <div class="flex items-center space-x-2 mb-4 overflow-x-auto pb-2 scrollbar-hide" data-ai-suggestions-target="filters">
    <button 
      data-action="click->ai-suggestions#filter" 
      data-category="all"
      class="px-3 py-1 text-xs font-medium rounded-full bg-gray-900 text-white dark:bg-white dark:text-gray-900 transition-colors whitespace-nowrap ring-2 ring-transparent focus:ring-primary-500"
    >
      All
    </button>
    <button 
      data-action="click->ai-suggestions#filter" 
      data-category="top"
      class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors whitespace-nowrap ring-2 ring-transparent focus:ring-primary-500"
    >
      Tops
    </button>
    <button 
      data-action="click->ai-suggestions#filter" 
      data-category="bottom"
      class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors whitespace-nowrap ring-2 ring-transparent focus:ring-primary-500"
    >
      Bottoms
    </button>
    <button 
      data-action="click->ai-suggestions#filter" 
      data-category="shoe"
      class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors whitespace-nowrap ring-2 ring-transparent focus:ring-primary-500"
    >
      Shoes
    </button>
    <button 
      data-action="click->ai-suggestions#filter" 
      data-category="accessory"
      class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors whitespace-nowrap ring-2 ring-transparent focus:ring-primary-500"
    >
      Accessories
    </button>
  </div>

  <div data-ai-suggestions-target="error" class="hidden mb-4 p-3 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700/50 text-red-800 dark:text-red-200 rounded text-sm"></div>
  
  <div data-ai-suggestions-target="list" class="min-h-[200px] transition-opacity duration-200">
    <div class="text-center py-12 text-gray-500 dark:text-gray-400">
      <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
      </svg>
      <p class="text-sm font-medium">Start adding items to your outfit</p>
      <p class="text-xs mt-1 text-gray-400">AI will suggest matching items instantly</p>
    </div>
  </div>
  
  <div data-ai-suggestions-target="loading" class="hidden">
    <div class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-2 border-gray-200 border-t-primary-600"></div>
      <p class="mt-3 text-sm font-medium text-gray-500">Finding perfect matches...</p>
    </div>
  </div>
</div>
