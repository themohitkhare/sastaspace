<div class="container mx-auto p-6" data-controller="outfit-builder">
  <h1 class="text-2xl font-semibold mb-4">Create Outfit</h1>

  <%= form_with model: @outfit, url: outfits_path, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full border rounded p-2" %>
    </div>
    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :description, rows: 3, class: "mt-1 block w-full border rounded p-2" %>
    </div>

    <%= render partial: "builder_canvas" %>
    <%= render partial: "ai_suggestions" %>

    <div>
      <%= f.submit "Save Outfit", class: "px-4 py-2 bg-blue-600 text-white rounded" %>
    </div>
  <% end %>
</div>

