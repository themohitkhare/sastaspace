<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Admin Dashboard</h1>
    <p class="mt-2 text-sm text-gray-600">Monitor system health and background jobs</p>
  </div>

  <!-- Navigation -->
  <div class="mb-6">
    <nav class="flex space-x-4">
      <%= link_to "Dashboard", admin_dashboard_path, class: "px-4 py-2 rounded-md bg-blue-600 text-white font-medium hover:bg-blue-700" %>
      <%= link_to "Job Monitoring", admin_job_monitoring_path, class: "px-4 py-2 rounded-md bg-gray-200 text-gray-700 font-medium hover:bg-gray-300" %>
      <%= link_to "Mission Control", "/admin/jobs/monitor", class: "px-4 py-2 rounded-md bg-gray-200 text-gray-700 font-medium hover:bg-gray-300" %>
    </nav>
  </div>

  <!-- Job Queue Health -->
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4">Job Queue Health</h2>
    
    <% if @job_health[:status] == "unavailable" %>
      <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4">
        <p class="text-yellow-800"><%= @job_health[:error] %></p>
      </div>
    <% else %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-<%= @job_health[:status] == "healthy" ? "green" : @job_health[:status] == "warning" ? "yellow" : "red" %>-50 border border-<%= @job_health[:status] == "healthy" ? "green" : @job_health[:status] == "warning" ? "yellow" : "red" %>-200 rounded-md p-4">
          <p class="text-sm font-medium text-<%= @job_health[:status] == "healthy" ? "green" : @job_health[:status] == "warning" ? "yellow" : "red" %>-800">Status</p>
          <p class="text-2xl font-bold text-<%= @job_health[:status] == "healthy" ? "green" : @job_health[:status] == "warning" ? "yellow" : "red" %>-900 capitalize"><%= @job_health[:status] %></p>
        </div>
        
        <div class="bg-blue-50 border border-blue-200 rounded-md p-4">
          <p class="text-sm font-medium text-blue-800">Active Workers</p>
          <p class="text-2xl font-bold text-blue-900"><%= @job_health[:workers][:active] %></p>
        </div>
        
        <div class="bg-purple-50 border border-purple-200 rounded-md p-4">
          <p class="text-sm font-medium text-purple-800">Active Alerts</p>
          <p class="text-2xl font-bold text-purple-900"><%= @job_health[:alerts].count %></p>
        </div>
      </div>

      <% if @job_health[:alerts].any? %>
        <div class="mt-4">
          <h3 class="text-lg font-semibold mb-2">Active Alerts</h3>
          <ul class="space-y-2">
            <% @job_health[:alerts].each do |alert| %>
              <li class="bg-<%= alert[:level] == "critical" ? "red" : "yellow" %>-50 border border-<%= alert[:level] == "critical" ? "red" : "yellow" %>-200 rounded-md p-3">
                <p class="text-sm font-medium text-<%= alert[:level] == "critical" ? "red" : "yellow" %>-800"><%= alert[:level].upcase %></p>
                <p class="text-sm text-<%= alert[:level] == "critical" ? "red" : "yellow" %>-700"><%= alert[:message] %></p>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Capacity Metrics -->
  <% if @capacity_metrics %>
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-xl font-semibold mb-4">Capacity Planning</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm font-medium text-gray-700 mb-2">Processing Rate</p>
          <p class="text-lg font-semibold"><%= @capacity_metrics[:processing_rate][:jobs_per_minute] %> jobs/minute</p>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-700 mb-2">Estimated Clearance Time</p>
          <p class="text-lg font-semibold"><%= @capacity_metrics[:processing_rate][:estimated_time_to_clear_minutes] %> minutes</p>
        </div>
      </div>
    </div>
  <% end %>
</div>

