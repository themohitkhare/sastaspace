<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Job Class Metrics: <%= @job_class %></h1>
    <p class="mt-2 text-sm text-gray-600">Performance metrics for <%= @job_class %></p>
  </div>

  <!-- Navigation -->
  <div class="mb-6">
    <nav class="flex space-x-4">
      <%= link_to "Dashboard", admin_dashboard_path, class: "px-4 py-2 rounded-md bg-gray-200 text-gray-700 font-medium hover:bg-gray-300" %>
      <%= link_to "Job Monitoring", admin_job_monitoring_path, class: "px-4 py-2 rounded-md bg-gray-200 text-gray-700 font-medium hover:bg-gray-300" %>
      <%= link_to "Mission Control", "/admin/jobs/monitor", class: "px-4 py-2 rounded-md bg-gray-200 text-gray-700 font-medium hover:bg-gray-300" %>
    </nav>
  </div>

  <!-- Metrics -->
  <% if @metrics && @metrics.any? %>
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-xl font-semibold mb-4">Performance Metrics</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <p class="text-sm text-gray-600">Total Jobs</p>
          <p class="text-2xl font-bold"><%= @metrics[:total] || 0 %></p>
        </div>
        <div>
          <p class="text-sm text-gray-600">Completed</p>
          <p class="text-2xl font-bold text-green-600"><%= @metrics[:completed] || 0 %></p>
        </div>
        <div>
          <p class="text-sm text-gray-600">Failed</p>
          <p class="text-2xl font-bold text-red-600"><%= @metrics[:failed] || 0 %></p>
        </div>
        <div>
          <p class="text-sm text-gray-600">Success Rate</p>
          <p class="text-2xl font-bold"><%= @metrics[:success_rate] || 0 %>%</p>
        </div>
        <div>
          <p class="text-sm text-gray-600">Avg Processing Time</p>
          <p class="text-2xl font-bold"><%= @metrics[:average_processing_time_ms] || 0 %>ms</p>
        </div>
      </div>
    </div>
  <% else %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4">
      <p class="text-yellow-800">No metrics available for <%= @job_class %></p>
    </div>
  <% end %>
</div>

