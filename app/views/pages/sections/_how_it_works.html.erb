<!-- How It Works Section -->
<section id="how-it-works" class="py-20 sm:py-24 bg-white dark:bg-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        Get Started in
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400">
          Four Simple Steps
        </span>
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300">
        From chaos to organized wardrobe in minutes
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Connecting Line (Desktop) -->
      <div class="hidden lg:block absolute top-16 left-0 right-0 h-1 bg-gradient-to-r from-blue-200 via-purple-200 to-pink-200 dark:from-blue-900 dark:via-purple-900 dark:to-pink-900" style="top: 4rem;"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
        <!-- Step 1 -->
        <div class="relative">
          <!-- Step Number -->
          <div class="relative flex items-center justify-center mb-6">
            <div class="w-32 h-32 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center shadow-xl transform transition hover:scale-110 hover:rotate-3">
              <span class="text-5xl font-bold text-white">1</span>
            </div>
          </div>

          <!-- Icon -->
          <div class="flex justify-center mb-6">
            <div class="w-20 h-20 bg-blue-100 dark:bg-blue-900/30 rounded-2xl flex items-center justify-center">
              <svg class="w-10 h-10 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
          </div>

          <!-- Content -->
          <div class="text-center">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
              Snap a Photo
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Take photos of your clothes, shoes, and accessories using your phone or camera. You can capture multiple items at once.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative">
          <!-- Step Number -->
          <div class="relative flex items-center justify-center mb-6">
            <div class="w-32 h-32 bg-gradient-to-br from-purple-500 to-purple-600 rounded-full flex items-center justify-center shadow-xl transform transition hover:scale-110 hover:rotate-3">
              <span class="text-5xl font-bold text-white">2</span>
            </div>
          </div>

          <!-- Icon -->
          <div class="flex justify-center mb-6">
            <div class="w-20 h-20 bg-purple-100 dark:bg-purple-900/30 rounded-2xl flex items-center justify-center">
              <svg class="w-10 h-10 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
          </div>

          <!-- Content -->
          <div class="text-center">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
              AI Analyzes Everything
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Our local AI instantly identifies colors, styles, materials, and brands. Everything is automatically categorized and organized.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative">
          <!-- Step Number -->
          <div class="relative flex items-center justify-center mb-6">
            <div class="w-32 h-32 bg-gradient-to-br from-pink-500 to-pink-600 rounded-full flex items-center justify-center shadow-xl transform transition hover:scale-110 hover:rotate-3">
              <span class="text-5xl font-bold text-white">3</span>
            </div>
          </div>

          <!-- Icon -->
          <div class="flex justify-center mb-6">
            <div class="w-20 h-20 bg-pink-100 dark:bg-pink-900/30 rounded-2xl flex items-center justify-center">
              <svg class="w-10 h-10 text-pink-600 dark:text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
              </svg>
            </div>
          </div>

          <!-- Content -->
          <div class="text-center">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
              Get Outfit Ideas
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Receive personalized outfit suggestions based on your wardrobe, the weather, your calendar, and your personal style preferences.
            </p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="relative">
          <!-- Step Number -->
          <div class="relative flex items-center justify-center mb-6">
            <div class="w-32 h-32 bg-gradient-to-br from-green-500 to-green-600 rounded-full flex items-center justify-center shadow-xl transform transition hover:scale-110 hover:rotate-3">
              <span class="text-5xl font-bold text-white">4</span>
            </div>
          </div>

          <!-- Icon -->
          <div class="flex justify-center mb-6">
            <div class="w-20 h-20 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center">
              <svg class="w-10 h-10 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"></path>
              </svg>
            </div>
          </div>

          <!-- Content -->
          <div class="text-center">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
              Look Your Best
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Save time, save money, reduce waste, and always know what to wear. Your wardrobe works smarter, not harder.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <%= link_to register_path, 
          class: "inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-lg text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transform transition hover:scale-105 shadow-lg hover:shadow-xl" do %>
        Start Your Journey Now
        <svg class="ml-2 -mr-1 w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
        </svg>
      <% end %>
      <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">
        No credit card required • Free forever • Set up in 5 minutes
      </p>
    </div>
  </div>
</section>
