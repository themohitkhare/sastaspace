<!-- Social Proof Section -->
<section class="py-20 sm:py-24 bg-gradient-to-b from-gray-50 to-white dark:from-gray-800 dark:to-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        Loved by Fashion-Forward Users
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300">
        Join thousands who've transformed their wardrobe experience
      </p>
    </div>

    <!-- Trust Metrics -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
      <div class="text-center">
        <div class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400 mb-2">
          50K+
        </div>
        <div class="text-sm text-gray-600 dark:text-gray-400">Items Analyzed</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-600 dark:from-purple-400 dark:to-pink-400 mb-2">
          10K+
        </div>
        <div class="text-sm text-gray-600 dark:text-gray-400">Outfits Created</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-green-600 to-teal-600 dark:from-green-400 dark:to-teal-400 mb-2">
          95%
        </div>
        <div class="text-sm text-gray-600 dark:text-gray-400">User Satisfaction</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-red-600 dark:from-orange-400 dark:to-red-400 mb-2">
          $500+
        </div>
        <div class="text-sm text-gray-600 dark:text-gray-400">Avg. Annual Savings</div>
      </div>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Testimonial 1 -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 border border-gray-200 dark:border-gray-700 shadow-lg hover:shadow-xl transition-shadow" data-landing-page-target="testimonial">
        <!-- Stars -->
        <div class="flex items-center mb-4">
          <% 5.times do %>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          <% end %>
        </div>

        <!-- Quote -->
        <blockquote class="text-gray-700 dark:text-gray-300 mb-6 leading-relaxed">
          "I've saved over <strong class="text-gray-900 dark:text-white">$500</strong> by avoiding duplicate purchases. The AI suggestions are spot-on, and I love that everything stays private on my device!"
        </blockquote>

        <!-- Author -->
        <div class="flex items-center">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-400 to-purple-500 rounded-full flex items-center justify-center text-white font-bold text-lg mr-3">
            A
          </div>
          <div>
            <div class="font-semibold text-gray-900 dark:text-white">Alex K.</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Power User • 6 months</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 2 -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 border border-gray-200 dark:border-gray-700 shadow-lg hover:shadow-xl transition-shadow" data-landing-page-target="testimonial">
        <!-- Stars -->
        <div class="flex items-center mb-4">
          <% 5.times do %>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          <% end %>
        </div>

        <!-- Quote -->
        <blockquote class="text-gray-700 dark:text-gray-300 mb-6 leading-relaxed">
          "Finally, an app that respects my privacy! The <strong class="text-gray-900 dark:text-white">local AI</strong> is a game-changer. No more worrying about my photos being stored in the cloud."
        </blockquote>

        <!-- Author -->
        <div class="flex items-center">
          <div class="w-12 h-12 bg-gradient-to-br from-green-400 to-teal-500 rounded-full flex items-center justify-center text-white font-bold text-lg mr-3">
            J
          </div>
          <div>
            <div class="font-semibold text-gray-900 dark:text-white">Jamie L.</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Privacy Advocate • 4 months</div>
          </div>
        </div>
      </div>

      <!-- Testimonial 3 -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 border border-gray-200 dark:border-gray-700 shadow-lg hover:shadow-xl transition-shadow" data-landing-page-target="testimonial">
        <!-- Stars -->
        <div class="flex items-center mb-4">
          <% 5.times do %>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          <% end %>
        </div>

        <!-- Quote -->
        <blockquote class="text-gray-700 dark:text-gray-300 mb-6 leading-relaxed">
          "My morning routine is <strong class="text-gray-900 dark:text-white">so much faster</strong> now. 5 minutes and I know exactly what to wear. The outfit suggestions are always perfect!"
        </blockquote>

        <!-- Author -->
        <div class="flex items-center">
          <div class="w-12 h-12 bg-gradient-to-br from-purple-400 to-pink-500 rounded-full flex items-center justify-center text-white font-bold text-lg mr-3">
            M
          </div>
          <div>
            <div class="font-semibold text-gray-900 dark:text-white">Morgan R.</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Busy Professional • 8 months</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust Badges -->
    <div class="flex flex-wrap justify-center items-center gap-8 pt-8 border-t border-gray-200 dark:border-gray-700">
      <div class="flex items-center space-x-2 text-gray-600 dark:text-gray-400">
        <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        <span class="text-sm font-medium">100% Privacy Protected</span>
      </div>
      
      <div class="flex items-center space-x-2 text-gray-600 dark:text-gray-400">
        <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-sm font-medium">GDPR Compliant</span>
      </div>
      
      <div class="flex items-center space-x-2 text-gray-600 dark:text-gray-400">
        <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
        </svg>
        <span class="text-sm font-medium">Open Source AI</span>
      </div>
      
      <div class="flex items-center space-x-2 text-gray-600 dark:text-gray-400">
        <svg class="w-6 h-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-sm font-medium">Free Forever</span>
      </div>
    </div>
  </div>
</section>
