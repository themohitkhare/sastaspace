<!-- Value Proposition Section -->
<section class="py-20 sm:py-24 bg-white dark:bg-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        Four Ways SastaSpace
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400">
          Transforms Your Life
        </span>
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300">
        More than just a digital closet—it's your personal fashion assistant
      </p>
    </div>

    <!-- Value Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Value 1: Save Money -->
      <div class="group relative bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-8 border border-green-200 dark:border-green-800 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div class="absolute top-4 right-4 text-6xl opacity-10 group-hover:opacity-20 transition-opacity">💰</div>
        <div class="relative">
          <!-- Icon -->
          <div class="w-16 h-16 bg-gradient-to-br from-green-500 to-emerald-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>

          <!-- Content -->
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">
            Save Money
          </h3>
          <p class="text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">
            Stop buying duplicates of items you already own. Our AI analyzes your wardrobe to prevent redundant purchases, saving you an average of 40% on fashion spending.
          </p>
          
          <!-- Stats -->
          <div class="flex items-center space-x-4 pt-4 border-t border-green-200 dark:border-green-800">
            <div>
              <div class="text-2xl font-bold text-green-600 dark:text-green-400">40%</div>
              <div class="text-sm text-gray-600 dark:text-gray-400">Average savings</div>
            </div>
            <div class="h-8 w-px bg-green-200 dark:bg-green-800"></div>
            <div>
              <div class="text-2xl font-bold text-green-600 dark:text-green-400">$500+</div>
              <div class="text-sm text-gray-600 dark:text-gray-400">Saved per year</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Value 2: Save Time -->
      <div class="group relative bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-8 border border-blue-200 dark:border-blue-800 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div class="absolute top-4 right-4 text-6xl opacity-10 group-hover:opacity-20 transition-opacity">⏱️</div>
        <div class="relative">
          <!-- Icon -->
          <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>

          <!-- Content -->
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">
            Save Time
          </h3>
          <p class="text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">
            Say goodbye to morning wardrobe stress. Get AI-powered outfit suggestions based on weather, occasion, and your personal style—all in under 5 minutes.
          </p>
          
          <!-- Stats -->
          <div class="flex items-center space-x-4 pt-4 border-t border-blue-200 dark:border-blue-800">
            <div>
              <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">5 min</div>
              <div class="text-sm text-gray-600 dark:text-gray-400">Per outfit decision</div>
            </div>
            <div class="h-8 w-px bg-blue-200 dark:bg-blue-800"></div>
            <div>
              <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">20+ hrs</div>
              <div class="text-sm text-gray-600 dark:text-gray-400">Saved per month</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Value 3: Look Better -->
      <div class="group relative bg-gradient-to-br from-purple-50 to-pink-50 dark:from-purple-900/20 dark:to-pink-900/20 rounded-2xl p-8 border border-purple-200 dark:border-purple-800 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div class="absolute top-4 right-4 text-6xl opacity-10 group-hover:opacity-20 transition-opacity">✨</div>
        <div class="relative">
          <!-- Icon -->
          <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
            </svg>
          </div>

          <!-- Content -->
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">
            Look Better
          </h3>
          <p class="text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">
            Discover new outfit combinations you never thought of. AI-backed style suggestions help you look your best every day with confidence.
          </p>
          
          <!-- Features -->
          <div class="space-y-2 pt-4 border-t border-purple-200 dark:border-purple-800">
            <div class="flex items-center text-sm text-gray-700 dark:text-gray-300">
              <svg class="w-5 h-5 text-purple-600 dark:text-purple-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Smart color coordination
            </div>
            <div class="flex items-center text-sm text-gray-700 dark:text-gray-300">
              <svg class="w-5 h-5 text-purple-600 dark:text-purple-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Occasion-appropriate styling
            </div>
            <div class="flex items-center text-sm text-gray-700 dark:text-gray-300">
              <svg class="w-5 h-5 text-purple-600 dark:text-purple-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Personalized recommendations
            </div>
          </div>
        </div>
      </div>

      <!-- Value 4: Live Sustainably -->
      <div class="group relative bg-gradient-to-br from-teal-50 to-cyan-50 dark:from-teal-900/20 dark:to-cyan-900/20 rounded-2xl p-8 border border-teal-200 dark:border-teal-800 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div class="absolute top-4 right-4 text-6xl opacity-10 group-hover:opacity-20 transition-opacity">🌱</div>
        <div class="relative">
          <!-- Icon -->
          <div class="w-16 h-16 bg-gradient-to-br from-teal-500 to-cyan-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>

          <!-- Content -->
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">
            Live Sustainably
          </h3>
          <p class="text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">
            Reduce fashion waste by maximizing what you already own. Get more wear from existing items through smart suggestions and avoid fast fashion traps.
          </p>
          
          <!-- Impact Stats -->
          <div class="space-y-2 pt-4 border-t border-teal-200 dark:border-teal-800">
            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-600 dark:text-gray-400">Wardrobe utilization</span>
              <span class="font-semibold text-teal-600 dark:text-teal-400">+65%</span>
            </div>
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
              <div class="bg-gradient-to-r from-teal-500 to-cyan-600 h-2 rounded-full" style="width: 65%"></div>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-600 dark:text-gray-400">Fashion waste reduction</span>
              <span class="font-semibold text-teal-600 dark:text-teal-400">-40%</span>
            </div>
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
              <div class="bg-gradient-to-r from-teal-500 to-cyan-600 h-2 rounded-full" style="width: 40%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <%= link_to register_path, 
          class: "inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-lg text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transform transition hover:scale-105 shadow-lg hover:shadow-xl" do %>
        Start Saving Money & Time Today
        <svg class="ml-2 -mr-1 w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
        </svg>
      <% end %>
    </div>
  </div>
</section>
