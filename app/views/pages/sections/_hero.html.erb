<!-- Hero Section -->
<section class="relative bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-800 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div class="text-center lg:text-left space-y-8" data-landing-page-target="heroText">
        <!-- Trust Badge -->
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800">
          <svg class="w-4 h-4 text-green-600 dark:text-green-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
          <span class="text-sm font-medium text-green-800 dark:text-green-300">100% Privacy-First • Your Data Never Leaves Your Device</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white leading-tight">
          Your AI-Powered Wardrobe,
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400">
            Smarter Every Day
          </span>
        </h1>

        <!-- Subheadline -->
        <p class="text-xl text-gray-600 dark:text-gray-300 leading-relaxed max-w-2xl mx-auto lg:mx-0">
          Save 40% on duplicate purchases. Get outfit suggestions in 5 minutes. 
          All with privacy-first AI that stays on your device.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <%= link_to register_path, 
              class: "inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transform transition hover:scale-105 shadow-lg hover:shadow-xl" do %>
            <span>Get Started Free</span>
            <svg class="ml-2 -mr-1 w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          <% end %>
          
          <a href="#how-it-works" 
             class="inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-lg text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 hover:bg-blue-100 dark:hover:bg-blue-900/30 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transform transition">
            <svg class="mr-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>Watch Demo</span>
          </a>
        </div>

        <!-- Quick Stats -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-8 pt-4">
          <div class="text-center lg:text-left">
            <div class="text-3xl font-bold text-gray-900 dark:text-white">40%</div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Savings on Duplicates</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-3xl font-bold text-gray-900 dark:text-white">5 min</div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Outfit Decisions</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-3xl font-bold text-gray-900 dark:text-white">100%</div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Privacy Protected</div>
          </div>
        </div>
      </div>

      <!-- Hero Image/Illustration -->
      <div class="relative lg:block" data-landing-page-target="heroImage">
        <div class="relative">
          <!-- Decorative elements -->
          <div class="absolute top-0 -left-4 w-72 h-72 bg-purple-300 dark:bg-purple-900 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-xl opacity-70 animate-blob"></div>
          <div class="absolute top-0 -right-4 w-72 h-72 bg-blue-300 dark:bg-blue-900 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
          <div class="absolute -bottom-8 left-20 w-72 h-72 bg-pink-300 dark:bg-pink-900 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>
          
          <!-- Placeholder for product mockup -->
          <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl p-8 border border-gray-200 dark:border-gray-700">
            <div class="space-y-4">
              <!-- Mockup: AI Analysis Result -->
              <div class="flex items-center space-x-3 pb-4 border-b border-gray-200 dark:border-gray-700">
                <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-blue-500 to-purple-600 rounded-xl flex items-center justify-center">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white">AI Analysis</h3>
                  <p class="text-sm text-gray-500 dark:text-gray-400">Item detected</p>
                </div>
              </div>
              
              <!-- Mockup: Item Cards -->
              <div class="grid grid-cols-2 gap-4">
                <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4 border border-gray-200 dark:border-gray-700">
                  <div class="aspect-square bg-gradient-to-br from-blue-100 to-blue-200 dark:from-blue-900 dark:to-blue-800 rounded-lg mb-3"></div>
                  <p class="text-sm font-medium text-gray-900 dark:text-white">Denim Jacket</p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">Casual • Blue</p>
                </div>
                <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4 border border-gray-200 dark:border-gray-700">
                  <div class="aspect-square bg-gradient-to-br from-purple-100 to-purple-200 dark:from-purple-900 dark:to-purple-800 rounded-lg mb-3"></div>
                  <p class="text-sm font-medium text-gray-900 dark:text-white">White Sneakers</p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">Footwear • White</p>
                </div>
              </div>
              
              <!-- Mockup: Action Button -->
              <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-4 rounded-lg transition">
                Get Outfit Suggestions
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative Wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg class="w-full h-20 text-white dark:text-gray-900" preserveAspectRatio="none" viewBox="0 0 1440 74" fill="none">
      <path d="M0 22L60 26.3C120 31 240 39 360 43.7C480 48 600 48 720 42.3C840 37 960 26 1080 22C1200 17 1320 20 1380 21.5L1440 23V74H1380C1320 74 1200 74 1080 74C960 74 840 74 720 74C600 74 480 74 360 74C240 74 120 74 60 74H0V22Z" fill="currentColor"/>
    </svg>
  </div>
</section>

<style>
  @keyframes blob {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(20px, -50px) scale(1.1); }
    50% { transform: translate(-20px, 20px) scale(0.9); }
    75% { transform: translate(50px, 50px) scale(1.05); }
  }
  
  .animate-blob {
    animation: blob 7s infinite;
  }
  
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
