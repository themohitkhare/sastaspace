<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">New Chat</h1>
  
  <div class="border rounded p-6 bg-white max-w-md">
    <%= form_with url: chats_path, method: :post do |f| %>
      <div class="mb-4">
        <%= f.label :message, "Message", class: "block text-sm font-medium mb-2" %>
        <%= f.text_field :message, class: "w-full px-3 py-2 border rounded" %>
      </div>
      
      <div class="mb-4">
        <%= f.label :model, "Model (optional)", class: "block text-sm font-medium mb-2" %>
        <%= f.text_field :model, placeholder: "gpt-4o-mini", class: "w-full px-3 py-2 border rounded" %>
      </div>
      
      <%= f.submit "Start Chat", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
    <% end %>
  </div>
</div>

