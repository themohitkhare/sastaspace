<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">Chats</h1>
  
  <div class="mb-4">
    <%= link_to "New Chat", new_chat_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <div class="grid gap-4">
    <% @chats.each do |chat| %>
      <div class="border p-4 rounded">
        <%= link_to "Chat ##{chat.id}", chat_path(chat), class: "text-blue-600 hover:text-blue-800" %>
        <p class="text-sm text-gray-600">Created: <%= chat.created_at.strftime("%Y-%m-%d %H:%M") %></p>
      </div>
    <% end %>
  </div>
</div>

