<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">Chat <%= @chat.id %></h1>
  
  <div class="mb-4">
    <%= link_to "Back to Chats", chats_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="border rounded p-4 bg-gray-50 mb-4">
    <h2 class="font-semibold mb-2">Messages</h2>
    <div class="space-y-2">
      <% @messages.each do |message| %>
        <div class="border-b pb-2">
          <strong><%= message.role.capitalize %>:</strong>
          <p><%= message.content %></p>
          <span class="text-xs text-gray-500"><%= message.created_at.strftime("%H:%M:%S") %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>

