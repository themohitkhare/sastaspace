<div
  data-controller="inventory"
  <% if current_user %>
    data-inventory-user-id-value="<%= current_user.id %>"
  <% end %>
  class="space-y-6"
>
  <!-- Header with Actions -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div class="flex items-center gap-3">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">My Inventory</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          <%= @inventory_items.respond_to?(:total_count) ? pluralize(@inventory_items.total_count, 'item') : pluralize(@inventory_items.count, 'item') %>
        </p>
      </div>
      <!-- Processing Indicator -->
      <div
        data-inventory-target="processingIndicator"
        class="hidden flex items-center gap-2 px-3 py-1.5 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-700 rounded-full"
      >
        <div class="relative">
          <div class="animate-spin rounded-full h-3 w-3 border-2 border-blue-600 border-t-transparent"></div>
          <div class="absolute inset-0 animate-ping rounded-full h-3 w-3 border border-blue-400 opacity-75"></div>
        </div>
        <span
          data-inventory-target="processingMessage"
          class="text-xs font-medium text-blue-700 dark:text-blue-300"
        >
          Processing items...
        </span>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <!-- View Toggle -->
      <div class="flex rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 p-1">
        <button
          data-action="click->inventory#switchToGridView"
          data-inventory-target="gridToggle"
          class="p-2 rounded-md transition-colors bg-primary-600 text-white"
          aria-label="Grid view"
          title="Grid view"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
          </svg>
        </button>
        <button
          data-action="click->inventory#switchToListView"
          data-inventory-target="listToggle"
          class="p-2 rounded-md transition-colors bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300"
          aria-label="List view"
          title="List view"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
      <%= link_to new_ai_inventory_items_path, class: "btn-primary inline-flex items-center gap-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
        </svg>
        Add Items with AI
      <% end %>
      <%= link_to new_inventory_item_path, class: "btn-secondary" do %>
        Add Item Manually
      <% end %>
    </div>
  </div>

  <!-- Bulk Actions Bar -->
  <div
    data-inventory-target="bulkActionsBar"
    class="hidden bg-primary-50 dark:bg-primary-900 border border-primary-200 dark:border-primary-700 rounded-lg p-4 flex items-center justify-between"
  >
    <span data-inventory-target="itemCount" class="text-sm font-medium text-primary-900 dark:text-primary-100"></span>
    <button
      data-action="click->inventory#bulkDelete"
      class="btn-danger text-sm"
    >
      Delete Selected
    </button>
  </div>

  <!-- Filters and Search -->
  <%= form_with url: inventory_items_path, method: :get, local: true, 
      data: { inventory_target: "filterForm" },
      class: "card p-4 space-y-4" do |form| %>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Search -->
      <div class="lg:col-span-2">
        <%= form.label :search, "Search", class: "form-label" %>
        <%= form.text_field :search,
            value: params[:search],
            placeholder: "Search by name or description...",
            data: { inventory_target: "searchInput" },
            class: "form-input" %>
      </div>

      <!-- Category Filter -->
      <div>
        <%= form.label :category_id, "Category", class: "form-label" %>
        <%= form.select :category_id,
            options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
            { include_blank: "All Categories" },
            { data: { inventory_target: "categoryFilter", action: "change->inventory#applyFilters" },
              class: "form-input" } %>
      </div>

      
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Color Filter -->
      <div>
        <%= form.label :color, "Color", class: "form-label" %>
        <%= form.select :color,
            options_for_select([["All Colors", ""]] + (@available_colors || []).map { |c| [c.titleize, c] }, params[:color]),
            {},
            { data: { inventory_target: "colorFilter", action: "change->inventory#applyFilters" },
              class: "form-input" } %>
      </div>

      <!-- Season Filter -->
      <div>
        <%= form.label :season, "Season", class: "form-label" %>
        <%= form.select :season,
            options_for_select([
              ["All Seasons", ""],
              ["Spring", "spring"],
              ["Summer", "summer"],
              ["Fall", "fall"],
              ["Winter", "winter"],
              ["All-Season", "all-season"]
            ], params[:season]),
            {},
            { data: { inventory_target: "seasonFilter", action: "change->inventory#applyFilters" },
              class: "form-input" } %>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <% if params[:search].present? || params[:category_id].present? || params[:color].present? || params[:season].present? %>
        <%= link_to "Clear Filters", inventory_items_path, 
            data: { action: "click->inventory#clearFilters" },
            class: "btn-secondary text-sm" %>
      <% end %>
    </div>
  <% end %>

  <!-- Content -->
  <% if @inventory_items.empty? %>
    <div class="card p-12 text-center">
      <svg class="w-16 h-16 mx-auto text-gray-400 dark:text-gray-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
      </svg>
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">
        <% if params[:search].present? || params[:category_id].present? %>
          No items found
        <% else %>
          You haven't added any items yet
        <% end %>
      </h3>
      <p class="text-gray-500 dark:text-gray-400 mb-6">
        <% if params[:search].present? %>
          No items match your search "<%= params[:search] %>"
        <% elsif params[:category_id].present? %>
          Try adjusting your filters
        <% else %>
          Get started by adding your first item to your inventory
        <% end %>
      </p>
      <%= link_to new_inventory_item_path, class: "btn-primary" do %>
        Add your first item
      <% end %>
    </div>
  <% else %>
    <!-- Grid View (default visible) -->
    <div data-inventory-target="gridView">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% @inventory_items.each do |item| %>
          <div data-inventory-target="itemCard" class="card group hover:shadow-lg transition-shadow">
            <!-- Checkbox for bulk selection -->
            <div class="absolute top-2 left-2 z-10 opacity-0 group-hover:opacity-100 transition-opacity">
              <%= check_box_tag "item_ids[]", item.id, false,
                  data: { inventory_target: "bulkCheckbox", action: "change->inventory#toggleItemSelection" },
                  class: "w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
            </div>

            <!-- Image -->
            <div class="aspect-square bg-gray-200 dark:bg-gray-700 rounded-t-lg overflow-hidden">
              <% if item.primary_image.attached? %>
                <%= link_to item do %>
                  <%= image_tag item.primary_image, alt: item.name,
                      class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
                <% end %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-gray-400 dark:text-gray-500">
                  <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </div>
              <% end %>
            </div>

            <!-- Content -->
            <div class="p-4">
              <%= link_to item, class: "block" do %>
                <h3 class="font-semibold text-gray-900 dark:text-white truncate hover:text-primary-600 dark:hover:text-primary-400">
                  <%= item.name %>
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                  <%= item.subcategory&.name || item.category.name %>
                </p>
              <% end %>
              
              <!-- Actions -->
              <div class="mt-3 flex items-center gap-2 pt-3 border-t border-gray-200 dark:border-gray-700">
                <%= link_to edit_inventory_item_path(item), 
                    class: "flex-1 text-center text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors",
                    title: "Edit" do %>
                  Edit
                <% end %>
                <%= link_to item, 
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete '#{item.name}'?" },
                    class: "flex-1 text-center text-sm text-red-600 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 transition-colors",
                    title: "Delete" do %>
                  Delete
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- List View -->
    <div data-inventory-target="listView" class="hidden">
      <div class="card overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-800">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                <%= check_box_tag "select_all", "", false,
                    data: { inventory_target: "selectAllCheckbox", action: "change->inventory#toggleSelectAll" },
                    class: "w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Item
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Category
              </th>
              
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Details
              </th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
            <% @inventory_items.each do |item| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= check_box_tag "item_ids[]", item.id, false,
                      data: { inventory_target: "bulkCheckbox", action: "change->inventory#toggleItemSelection" },
                      class: "w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10">
                      <% if item.primary_image.attached? %>
                        <%= image_tag item.primary_image, alt: item.name,
                            class: "h-10 w-10 rounded-full object-cover" %>
                      <% else %>
                        <div class="h-10 w-10 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
                          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                        </div>
                      <% end %>
                    </div>
                    <div class="ml-4">
                      <%= link_to item, class: "text-sm font-medium text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400" do %>
                        <%= item.name %>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= item.category.name %>
                </td>
                
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <% if item.description.present? %>
                    <span class="truncate max-w-xs block" title="<%= item.description %>">
                      <%= truncate(item.description, length: 50) %>
                    </span>
                  <% else %>
                    <span class="text-gray-400">—</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <%= link_to "View", item, class: "text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-300 mr-4" %>
                  <%= link_to "Edit", edit_inventory_item_path(item), class: "text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-300 mr-4" %>
                  <%= link_to "Delete", item, 
                      data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete '#{item.name}'?" },
                      class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <% if @inventory_items.respond_to?(:current_page) %>
      <div class="mt-8 flex items-center justify-between border-t border-gray-200 dark:border-gray-700 pt-4">
        <div class="text-sm text-gray-700 dark:text-gray-300">
          Showing <%= @inventory_items.offset_value + 1 %> to <%= [@inventory_items.offset_value + @inventory_items.limit_value, @inventory_items.total_count].min %> of <%= @inventory_items.total_count %> results
        </div>
        <div class="flex gap-2">
          <%= paginate @inventory_items, class: "flex gap-2" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
