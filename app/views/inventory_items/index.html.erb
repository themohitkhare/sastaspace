<div style="max-width: 1200px; margin: 0 auto; padding: 20px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <h1>My Inventory</h1>
    <%= link_to "Add Item", new_inventory_item_path, style: "padding: 10px 20px; background: #28a745; color: white; text-decoration: none; border-radius: 4px;" %>
  </div>

  <% if flash[:notice] %>
    <div style="color: green; padding: 10px; margin-bottom: 15px; border: 1px solid green; background: #d4edda;">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div style="display: flex; gap: 20px; margin-bottom: 30px;">
    <div style="flex: 1;">
      <%= form_with url: inventory_items_path, method: :get, local: true, style: "display: flex; gap: 10px;" do |form| %>
        <%= form.text_field :search, placeholder: "Search", value: params[:search], style: "flex: 1; padding: 8px;" %>
        <%= form.submit "Search", style: "padding: 8px 15px; background: #007bff; color: white; border: none; cursor: pointer;" %>
        <% if params[:search].present? %>
          <%= link_to "Clear", inventory_items_path, style: "padding: 8px 15px; background: #6c757d; color: white; text-decoration: none; border-radius: 4px;" %>
        <% end %>
      <% end %>
    </div>

    <div>
      <%= form_with url: inventory_items_path, method: :get, local: true do |form| %>
        <%= form.hidden_field :search, value: params[:search] %>
        <%= form.label :category_id, "Filter by Category", style: "display: none;" %>
        <%= form.select :category_id, options_from_collection_for_select(@categories, :id, :name, params[:category_id]), { include_blank: "Filter by Category" }, { style: "padding: 8px;" } %>
        <%= form.submit "Filter", style: "padding: 8px 15px; background: #17a2b8; color: white; border: none; cursor: pointer; margin-left: 10px;" %>
        <% if params[:category_id].present? %>
          <%= link_to "Clear Filter", inventory_items_path(search: params[:search]), style: "padding: 8px 15px; background: #6c757d; color: white; text-decoration: none; border-radius: 4px; margin-left: 10px;" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @inventory_items.empty? %>
    <div style="text-align: center; padding: 40px;">
      <p style="font-size: 18px; color: #6c757d; margin-bottom: 20px;">You haven't added any items yet</p>
      <%= link_to "Add your first item", new_inventory_item_path, style: "padding: 10px 20px; background: #28a745; color: white; text-decoration: none; border-radius: 4px;" %>
    </div>
  <% else %>
    <div style="margin-bottom: 15px;">
      <p><strong><%= @inventory_items.count %> <%= @inventory_items.count == 1 ? 'item' : 'items' %></strong></p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px;">
      <% @inventory_items.each do |item| %>
        <div style="border: 1px solid #ddd; border-radius: 8px; padding: 15px;">
          <% if item.primary_image.attached? %>
            <%= image_tag item.primary_image, alt: item.name, style: "width: 100%; height: 200px; object-fit: cover; border-radius: 4px; margin-bottom: 10px;" %>
          <% end %>
          <h3 style="margin: 0 0 10px 0;">
            <%= link_to item.name, item, style: "color: #007bff; text-decoration: none;" %>
          </h3>
          <p style="color: #6c757d; margin: 0;"><%= item.category.name %></p>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if params[:search].present? && @inventory_items.empty? %>
    <div style="text-align: center; padding: 40px;">
      <p style="font-size: 18px; color: #6c757d;">No items found matching "<%= params[:search] %>"</p>
    </div>
  <% elsif params[:category_id].present? && @inventory_items.empty? %>
    <div style="text-align: center; padding: 40px;">
      <p style="font-size: 18px; color: #6c757d;">No items found in this category</p>
    </div>
  <% end %>
</div>

