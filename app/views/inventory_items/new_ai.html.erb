<div data-controller="inventory-creation-analyzer" class="max-w-6xl mx-auto">
  <div class="card">
    <div class="card-header">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Add Items with AI</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Upload an image and let AI detect all clothing items for you</p>
    </div>

    <div class="card-body space-y-6">
      <!-- Step 1: Image Upload (AI Analysis) -->
      <div data-inventory-creation-analyzer-target="uploadStep" class="space-y-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Step 1: Upload Image</h2>
        
        <!-- Image Upload Area -->
        <div 
          data-inventory-creation-analyzer-target="uploadArea"
          class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-8 text-center hover:border-primary-500 dark:hover:border-primary-400 transition-colors cursor-pointer"
          data-action="click->inventory-creation-analyzer#triggerFileInput dragover->inventory-creation-analyzer#handleDragOver drop->inventory-creation-analyzer#handleDrop"
        >
          <input
            type="file"
            accept="image/*"
            data-inventory-creation-analyzer-target="fileInput"
            data-action="change->inventory-creation-analyzer#handleFileSelect"
            class="hidden"
          />
          
          <div data-inventory-creation-analyzer-target="uploadPrompt">
            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
              <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
              <span class="font-semibold">Click to upload</span> or drag and drop
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-500 mt-1">PNG, JPG, WebP up to 10MB</p>
          </div>

          <!-- Image Preview -->
          <div data-inventory-creation-analyzer-target="imagePreview" class="hidden">
            <img data-inventory-creation-analyzer-target="previewImage" src="" alt="Preview" class="max-h-64 mx-auto rounded-lg" />
            <p data-inventory-creation-analyzer-target="previewName" class="mt-2 text-sm text-gray-600 dark:text-gray-400"></p>
          </div>
        </div>

        <!-- Loading State -->
        <div data-inventory-creation-analyzer-target="loadingState" class="hidden">
          <div class="flex items-center justify-center p-8">
            <div class="text-center">
              <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600"></div>
              <p class="mt-4 text-gray-700 dark:text-gray-300">Detecting clothing items...</p>
              <p class="mt-2 text-sm text-gray-500 dark:text-gray-500">This may take a few moments</p>
            </div>
          </div>
        </div>

        <!-- Error State -->
        <div data-inventory-creation-analyzer-target="errorState" class="hidden p-4 bg-red-50 border border-red-200 text-red-800 rounded dark:bg-red-900 dark:border-red-700 dark:text-red-200">
          <p data-inventory-creation-analyzer-target="errorMessage"></p>
          <button
            type="button"
            data-action="click->inventory-creation-analyzer#cancelReview"
            class="mt-2 text-sm underline"
          >
            Try again
          </button>
        </div>

      </div>

      <!-- Step 2: Success State (Items Created) -->
      <div data-inventory-creation-analyzer-target="successStep" class="hidden space-y-4">
        <div class="text-center py-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 dark:bg-green-900 mb-4">
            <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-2">Image Uploaded Successfully!</h2>
          <p data-inventory-creation-analyzer-target="successMessage" class="text-gray-600 dark:text-gray-400 mb-6">
            Your image has been queued for processing.
          </p>
          
          <!-- Action Buttons -->
          <div class="flex justify-center gap-4">
            <button
              type="button"
              data-action="click->inventory-creation-analyzer#addMore"
              class="btn-primary"
            >
              Add More Items
            </button>
            <%= link_to "View My Inventory", inventory_items_path, class: "btn-secondary" %>
          </div>
        </div>
      </div>

      <!-- Step 3: Review Detected Items (Legacy - kept for backward compatibility) -->
      <div data-inventory-creation-analyzer-target="reviewStep" class="hidden space-y-4">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Review Detected Items</h2>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
              Select the items you want to add to your inventory
            </p>
          </div>
          <div class="text-sm text-gray-600 dark:text-gray-400">
            <span data-inventory-creation-analyzer-target="selectedItemsCount">0 items selected</span>
          </div>
        </div>

        <!-- Detected Items Grid -->
        <div data-inventory-creation-analyzer-target="itemsGrid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Items will be rendered here by JavaScript -->
        </div>

        <!-- Action Buttons -->
        <div class="flex justify-between pt-6 border-t border-gray-200 dark:border-gray-700">
          <button
            type="button"
            data-action="click->inventory-creation-analyzer#cancelReview"
            class="btn-secondary"
          >
            Upload Different Image
          </button>

          <div class="flex gap-3">
            <%= link_to "Cancel", inventory_items_path, class: "btn-secondary" %>
            <button
              type="button"
              data-action="click->inventory-creation-analyzer#createItems"
              data-inventory-creation-analyzer-target="createButton"
              class="btn-primary"
              disabled
            >
              Create Selected Items
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

