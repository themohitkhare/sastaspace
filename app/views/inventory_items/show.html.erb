<div style="max-width: 1000px; margin: 0 auto; padding: 20px;">
  <div style="margin-bottom: 20px;">
    <%= link_to "← Back to Inventory", inventory_items_path, style: "color: #007bff; text-decoration: none;" %>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
    <div>
      <% if @inventory_item.primary_image.attached? %>
        <%= image_tag @inventory_item.primary_image, alt: @inventory_item.name, style: "width: 100%; border-radius: 8px; border: 1px solid #ddd;" %>
      <% else %>
        <div style="width: 100%; height: 400px; background: #f0f0f0; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #6c757d;">
          No image
        </div>
      <% end %>

      <% if @inventory_item.additional_images.attached? %>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 10px; margin-top: 15px;">
          <% @inventory_item.additional_images.each do |image| %>
            <%= image_tag image, alt: "Additional image", style: "width: 100%; height: 100px; object-fit: cover; border-radius: 4px; border: 1px solid #ddd;" %>
          <% end %>
        </div>
      <% end %>

      <div style="margin-top: 20px;">
        <%= link_to "Add Image", "#", style: "padding: 8px 15px; background: #17a2b8; color: white; text-decoration: none; border-radius: 4px; display: inline-block;" %>
      </div>
    </div>

    <div>
      <h1 style="margin-top: 0;"><%= @inventory_item.name %></h1>

      <div style="margin-bottom: 15px;">
        <strong>Category:</strong> <%= @inventory_item.category.name %>
        <% if @inventory_item.subcategory.present? %>
          <span style="color: #6c757d;"> → <%= @inventory_item.subcategory.name %></span>
        <% end %>
      </div>

      <% if @inventory_item.description.present? %>
        <div style="margin-bottom: 15px;">
          <strong>Description:</strong>
          <p><%= @inventory_item.description %></p>
        </div>
      <% end %>

      <!-- Stock Photo Extraction Section -->
      <% if @inventory_item.primary_image.attached? && @inventory_item.primary_image.blob.present? %>
        <div 
          data-controller="stock-photo-extraction"
          data-stock-photo-extraction-blob-id-value="<%= @inventory_item.primary_image.blob.id %>"
          data-stock-photo-extraction-analysis-results-value="<%= j({
            name: @inventory_item.name,
            category_name: @inventory_item.category&.name,
            category_matched: @inventory_item.category&.name,
            subcategory: @inventory_item.subcategory&.name,
            material: @inventory_item.material,
            style: @inventory_item.style_notes,
            style_notes: @inventory_item.style_notes,
            brand_matched: @inventory_item.brand&.name,
            colors: [@inventory_item.color].compact,
            extraction_prompt: @inventory_item.extraction_prompt,
            gender_appropriate: true,
            confidence: 0.9
          }.to_json) %>"
          style="margin-top: 20px; padding: 15px; background: #f8f9fa; border-radius: 8px; border: 1px solid #dee2e6;"
        >
          <h3 style="margin-top: 0; margin-bottom: 10px; font-size: 16px; font-weight: 600;">Stock Photo Extraction</h3>
          <p style="margin-bottom: 15px; color: #6c757d; font-size: 14px;">
            Generate a professional stock photo with white background using AI.
          </p>
          
          <button
            data-stock-photo-extraction-target="button"
            data-action="click->stock-photo-extraction#extractStockPhoto"
            class="btn-primary"
            style="padding: 8px 15px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;"
          >
            Extract Stock Photo
          </button>

          <div 
            data-stock-photo-extraction-target="status"
            class="hidden"
            style="margin-top: 10px; padding: 10px; background: #e7f3ff; border-radius: 4px; color: #004085; font-size: 14px;"
          >
            <span data-stock-photo-extraction-target="progress">⏳ </span>
            <span>Processing...</span>
          </div>

          <div 
            data-stock-photo-extraction-target="errorMessage"
            class="hidden"
            style="margin-top: 10px; padding: 10px; background: #f8d7da; border-radius: 4px; color: #721c24; font-size: 14px;"
          >
          </div>

          <div 
            data-stock-photo-extraction-target="extractedImage"
            class="hidden"
            style="margin-top: 10px;"
          >
          </div>
        </div>
      <% end %>

      <div style="margin-top: 30px;">
        <%= link_to "Edit", edit_inventory_item_path(@inventory_item), style: "padding: 8px 15px; background: #ffc107; color: #000; text-decoration: none; border-radius: 4px; margin-right: 10px;" %>
        <%= link_to "Delete", @inventory_item, data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete '#{@inventory_item.name}'?" }, style: "padding: 8px 15px; background: #dc3545; color: white; text-decoration: none; border-radius: 4px;" %>
      </div>
    </div>
  </div>
</div>

