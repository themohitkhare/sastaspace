<% if flash.any? %>
  <div data-controller="flash" class="fixed top-4 right-4 z-50 max-w-md">
    <% flash.each do |type, message| %>
      <% 
        bg_color = case type.to_s
        when "notice", "success"
          "bg-green-50 border-green-200 text-green-800 dark:bg-green-900 dark:border-green-700 dark:text-green-200"
        when "alert", "error"
          "bg-red-50 border-red-200 text-red-800 dark:bg-red-900 dark:border-red-700 dark:text-red-200"
        when "info"
          "bg-blue-50 border-blue-200 text-blue-800 dark:bg-blue-900 dark:border-blue-700 dark:text-blue-200"
        when "warning"
          "bg-yellow-50 border-yellow-200 text-yellow-800 dark:bg-yellow-900 dark:border-yellow-700 dark:text-yellow-200"
        else
          "bg-gray-50 border-gray-200 text-gray-800 dark:bg-gray-900 dark:border-gray-700 dark:text-gray-200"
        end
      %>
      <div class="<%= bg_color %> border rounded-lg shadow-lg p-4 mb-2 flex items-center justify-between">
        <p class="flex-1"><%= message %></p>
        <button 
          data-action="click->flash#dismiss" 
          class="ml-4 text-current opacity-70 hover:opacity-100 focus:outline-none"
          aria-label="Dismiss"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    <% end %>
  </div>
<% end %>

