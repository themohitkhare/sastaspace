<% if defined?(exception) && exception %>
  <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-4" data-controller="error-boundary">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
      </div>
      <div class="ml-3 flex-1">
        <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
          An error occurred
        </h3>
        <div class="mt-2 text-sm text-red-700 dark:text-red-300">
          <p><%= exception.message %></p>
          <% if Rails.env.development? %>
            <details class="mt-2">
              <summary class="cursor-pointer text-xs">Show details</summary>
              <pre class="mt-2 text-xs overflow-auto"><%= exception.backtrace.join("\n") %></pre>
            </details>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

