# Public origin of the typewars front-end. Used by SignInTrigger to bake the
# magic-link callback URL. Override per-environment (e.g. http://localhost:3000
# for local dev).
NEXT_PUBLIC_TYPEWARS_ORIGIN=https://typewars.sastaspace.com

# SpacetimeDB endpoints (used by /auth/verify and the live connection).
NEXT_PUBLIC_STDB_URI=wss://stdb.sastaspace.com
NEXT_PUBLIC_STDB_HTTP=https://stdb.sastaspace.com
NEXT_PUBLIC_TYPEWARS_MODULE=typewars
NEXT_PUBLIC_SASTA_MODULE=sastaspace

# Phase 2 F2: when "true", sign-in routes through the STDB reducer flow
# (request_magic_link + /auth/verify). When "false" or absent, the legacy
# FastAPI auth.sastaspace.com flow (POST /auth/request + /auth/callback) runs.
# Default to "false" until Phase 3 cutover.
NEXT_PUBLIC_USE_STDB_AUTH=false
