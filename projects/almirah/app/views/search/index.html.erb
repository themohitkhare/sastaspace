<% content_for :title, "Search — Almirah" %>
<div class="app">
  <%= render "shared/appbar",
        left: capture { link_to root_path, class: "iconbtn", "aria-label": "back" do
          raw '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>'
        end } %>

  <%# Search form — submits GET so the URL is bookmarkable %>
  <div style="padding:10px 20px 12px;border-bottom:1px solid var(--brand-dust-40);">
    <%= form_with url: search_path, method: :get, local: true, style: "display:flex;gap:10px;align-items:center;" do |f| %>
      <%= f.search_field :q, value: @query, autofocus: true,
            placeholder: "kurta, indigo, office...",
            autocomplete: "off",
            style: "flex:1;padding:11px 14px;background:var(--brand-paper-lifted);border:1px solid var(--brand-dust-40);border-radius:10px;font-family:var(--font-sans);font-size:15px;color:var(--brand-ink);",
            class: "field" %>
      <%= f.submit "Search", class: "btn btn--primary btn--sm" %>
    <% end %>
  </div>

  <div class="scroll--pad scroll">
    <% if @query.present? && @results.any? %>
      <div style="padding-top:16px;">
        <div class="meta-mono" style="margin-bottom:16px;"><%= @results.count %> result<%= @results.count == 1 ? "" : "s" %> for &#8220;<%= @query %>&#8221;</div>
        <div class="grid-3">
          <% @results.each do |item| %>
            <%= link_to item_path(item), style: "aspect-ratio:3/4;text-decoration:none;" do %>
              <%= render "shared/item_card", item: item, size: :md, show_name: true %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% elsif @query.present? %>
      <div style="padding-top:40px;text-align:center;color:var(--brand-muted);">
        No items match &#8220;<%= @query %>&#8221;.
      </div>
    <% else %>
      <div style="padding-top:40px;text-align:center;color:var(--brand-muted);">
        <p class="meta-mono">search by item type, colour, rack, or name</p>
        <p style="font-size:13px;line-height:1.6;">e.g. &#8220;indigo kurta&#8221;, &#8220;office&#8221;, &#8220;lehenga&#8221;</p>
      </div>
    <% end %>
  </div>

  <%= render "shared/tabbar", active: "search" %>
</div>
