# Almirah local dev env — copy to .env.local (git-ignored) and fill in.
# Production values live in the `almirah-runtime` k8s secret.

# --- Supabase (shared sastaspace infra) ---
# Public browser-facing Supabase URL (Cloudflare-fronted).
NEXT_PUBLIC_SUPABASE_URL=https://api.sastaspace.com
# Anon key for the Supabase project — browser-safe by design.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: cluster-internal Supabase URL for server-side calls. In k8s this
# is set to http://gateway.sastaspace.svc.cluster.local:8000. Leave unset for
# local dev.
# SUPABASE_INTERNAL_URL=

# --- LiteLLM → Gemma 4 (cluster-internal vision/tagging) ---
# For local dev: port-forward the cluster service
#   kubectl -n litellm port-forward svc/litellm 4000:4000
LITELLM_BASE_URL=http://localhost:4000
# LiteLLM master key. Keep secret. Same value goes into the almirah-runtime
# k8s secret under the same name.
LITELLM_API_KEY=
