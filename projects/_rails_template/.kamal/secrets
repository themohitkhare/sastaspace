# .kamal/secrets — sourced by Kamal at deploy time.
#
# Pull secrets from environment or macOS Keychain. Never hardcode values here.
# This file IS committed to git — it must contain only variable names + fetch commands.
#
# Required for all sastaspace Rails apps:
#   SECRET_KEY_BASE     — Rails encrypted session/cookie key
#   POSTGRES_URL        — Full postgres:// connection URL
#   GOOGLE_CLIENT_ID    — Google OAuth client ID
#   GOOGLE_CLIENT_SECRET — Google OAuth client secret
#   LITELLM_API_KEY     — LiteLLM proxy API key (cluster-local)

RAILS_MASTER_KEY=$(cat config/master.key)
SECRET_KEY_BASE=$(cat config/master.key)
POSTGRES_URL=$POSTGRES_URL
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
LITELLM_API_KEY=$LITELLM_API_KEY

# No registry password needed for localhost:32000 (unauthenticated local registry).
# KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
