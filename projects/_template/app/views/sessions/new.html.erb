<% content_for :title, "Sign in — sastaspace" %>

<div class="max-w-sm mx-auto py-16 px-4">
  <p class="font-mono text-sm text-dust mb-8 tracking-wide">sastaspace.com —</p>

  <h1 class="text-3xl font-medium tracking-tight text-ink mb-2">Sign in</h1>
  <p class="text-sm text-muted mb-8">to your sastaspace account</p>

  <%# Flash messages %>
  <% if alert = flash[:alert] %>
    <p class="text-sm text-rust border border-rust/30 bg-rust/5 rounded px-3 py-2 mb-6" role="alert"><%= alert %></p>
  <% end %>

  <%# Google OAuth — POST to /auth/google initiates the OAuth flow.
      omniauth-rails_csrf_protection requires a form POST, not a GET link. %>
  <%= button_to "/auth/google",
        method: :post,
        class: "w-full flex items-center justify-center gap-3 border border-dust/40 rounded px-4 py-2.5 text-sm font-medium text-ink hover:bg-paper-lifted transition-colors mb-6" do %>
    <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    Continue with Google
  <% end %>

  <div class="relative flex items-center gap-3 mb-6">
    <div class="flex-1 h-px bg-dust/30"></div>
    <span class="text-xs text-dust font-mono">or</span>
    <div class="flex-1 h-px bg-dust/30"></div>
  </div>

  <%# Email + password form %>
  <%= form_with url: session_path, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email_address, "Email", class: "block text-sm font-medium text-ink mb-1" %>
      <%= f.email_field :email_address,
            required: true,
            autofocus: true,
            autocomplete: "username",
            placeholder: "you@example.com",
            value: params[:email_address],
            class: "block w-full border border-dust/40 rounded px-3 py-2 text-sm text-ink bg-paper-lifted placeholder:text-dust focus:outline-none focus:border-sasta" %>
    </div>

    <div>
      <%= f.label :password, "Password", class: "block text-sm font-medium text-ink mb-1" %>
      <%= f.password_field :password,
            required: true,
            autocomplete: "current-password",
            placeholder: "••••••••",
            maxlength: 72,
            class: "block w-full border border-dust/40 rounded px-3 py-2 text-sm text-ink bg-paper-lifted placeholder:text-dust focus:outline-none focus:border-sasta" %>
    </div>

    <div class="flex items-center justify-between pt-1">
      <%= f.submit "Sign in",
            class: "px-4 py-2 bg-sasta text-paper rounded text-sm font-medium hover:bg-rust transition-colors cursor-pointer" %>
      <%= link_to "Forgot password?", new_password_path,
            class: "text-sm text-rust hover:text-ink" %>
    </div>
  <% end %>
</div>
