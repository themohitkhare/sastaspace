<% content_for :title, "#{@item.name.capitalize} — Almirah" %>
<div class="app">
  <%= render "shared/appbar",
        left: capture { link_to root_path, class: "iconbtn", "aria-label": "back" do
          raw '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>'
        end },
        right: nil %>

  <div class="scroll" style="padding:4px 20px 96px;">
    <%# Hero stage %>
    <div class="stage" style="background:<%= @item.tone_bg %>;">
      <div class="stage-hangerline"></div>
      <svg viewBox="0 0 100 100" width="200" height="200" aria-hidden="true">
        <%= raw AlmirahHelper::SILHOUETTE_PATHS.fetch(@item.kind, AlmirahHelper::SILHOUETTE_PATHS["shirt"]) %>
      </svg>
      <div style="position:absolute;bottom:10px;left:14px;font-family:var(--font-mono);font-size:10px;color:var(--brand-ink);letter-spacing:0.04em;background:rgba(245,241,232,0.7);padding:2px 6px;border-radius:4px;">
        pulled from <%= @item.rack %>
      </div>
    </div>

    <%# Title + tag chips %>
    <div style="margin-top:16px;">
      <h1 style="font-size:22px;font-weight:500;letter-spacing:-0.015em;margin:0;line-height:1.2;">
        <%= @item.name.capitalize %>
      </h1>
      <div style="margin-top:6px;display:flex;gap:8px;flex-wrap:wrap;">
        <span class="tag">
          <span class="swatch" style="background:<%= @item.tone_swatch %>;"></span>
          <%= @item.tone %>
        </span>
        <span class="tag"><%= @item.kind %></span>
        <% if @item.price_inr %>
          <span class="tag"><%= @item.formatted_price %></span>
        <% end %>
        <span class="tag">last <%= @item.last_worn_ago %> ago</span>
      </div>
      <div style="margin-top:10px;" class="meta-mono">
        worn <%= @item.wears_count %> times ·
        <% if @item.last_worn_at %>
          last wear <%= @item.last_worn_ago %> ago
        <% else %>
          never worn
        <% end %>
      </div>
    </div>

    <%# Complete the look pairings %>
    <% if @pairings.any? %>
      <div style="margin-top:26px;">
        <div class="eyebrow" style="display:flex;align-items:center;gap:6px;margin-bottom:10px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2z"/></svg>
          <span>complete the look</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <% @pairings.each do |pairing| %>
            <div class="card" style="padding:14px;">
              <div style="font-size:13px;font-weight:500;letter-spacing:-0.005em;margin-bottom:10px;"><%= pairing[:title] %></div>
              <div style="display:grid;grid-template-columns:repeat(<%= pairing[:items].size %>,1fr);gap:8px;">
                <% pairing[:items].each do |pair_item| %>
                  <%= link_to item_path(pair_item), style: "aspect-ratio:3/4;text-decoration:none;" do %>
                    <%= render "shared/item_card", item: pair_item, size: :sm, show_name: false %>
                  <% end %>
                <% end %>
              </div>
              <div style="display:flex;gap:8px;margin-top:10px;">
                <button class="btn btn--sm btn--primary" style="flex:1;justify-content:center;" disabled>save as outfit</button>
                <button class="btn btn--sm btn--ghost"   style="flex:1;justify-content:center;" disabled>swap one</button>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Wear log %>
    <% if @wear_events.any? %>
      <div style="margin-top:26px;">
        <div class="eyebrow" style="margin-bottom:10px;">wear log</div>
        <% @wear_events.each do |we| %>
          <div class="row">
            <div>
              <div style="font-size:14px;font-weight:500;"><%= we.event_name.presence || "worn" %></div>
              <div class="meta-mono"><%= we.worn_at.strftime("%b %d, %Y") %></div>
            </div>
            <% if we.attendees.any? %>
              <div class="meta-mono"><%= we.attendees.first(3).join(", ") %></div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= link_to search_path, class: "btn btn--ghost btn--block", style: "margin-top:18px;color:var(--brand-muted);" do %>
      show similar items in your rack
    <% end %>
  </div>

  <%= render "shared/tabbar", active: "rack" %>
</div>
