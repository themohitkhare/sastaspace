<% content_for :title, "Add items — Almirah" %>
<div class="app">
  <%= render "shared/appbar",
        left: capture { link_to root_path, class: "iconbtn", "aria-label": "back" do
          raw '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>'
        end } %>

  <div class="scroll--pad scroll">
    <div style="padding-top:24px;">
      <p class="eyebrow" style="margin-bottom:8px;">onboarding</p>
      <h1 style="font-size:26px;font-weight:500;letter-spacing:-0.015em;margin:0 0 8px;">
        Add your wardrobe
      </h1>
      <p style="font-size:15px;color:var(--brand-muted);margin:0 0 28px;line-height:1.5;">
        Upload photos from your camera roll. Each photo is tagged by AI — kind, colour, occasion.
        Up to 20 images per batch, JPEG / PNG / WebP / GIF, max 8 MB each.
      </p>

      <%= form_with url: ingest_start_path, method: :post, multipart: true, local: true do |f| %>
        <div style="border:2px dashed var(--brand-dust-40);border-radius:16px;padding:32px 20px;text-align:center;margin-bottom:24px;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="color:var(--brand-dust);margin:0 auto 12px;display:block;" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <p style="font-size:14px;color:var(--brand-muted);margin:0 0 12px;">drag photos here or</p>
          <%= f.file_field :images, multiple: true, accept: "image/jpeg,image/png,image/webp,image/gif",
                style: "display:none;", id: "images_input",
                data: { onchange: "document.getElementById('submit_btn').disabled = !this.files.length;" } %>
          <label for="images_input" class="btn btn--ghost btn--sm" style="cursor:pointer;display:inline-flex;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Choose photos
          </label>
        </div>

        <script>
          document.getElementById('images_input')?.addEventListener('change', function() {
            var label = document.querySelector('[for="images_input"]');
            if (label) label.textContent = this.files.length + ' file(s) selected';
            var btn = document.getElementById('submit_btn');
            if (btn) btn.disabled = !this.files.length;
          });
        </script>

        <%= f.submit "Tag and add to rack →",
              id: "submit_btn",
              disabled: true,
              class: "btn btn--sasta btn--block" %>
      <% end %>

      <p class="meta-mono" style="margin-top:16px;text-align:center;">
        AI reads each photo for garment type, colour, and occasion. No photo is stored without your review.
      </p>
    </div>
  </div>
</div>
