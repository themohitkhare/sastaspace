{
  "name": "sastaspace",
  "private": true,
  "version": "0.1.0",
  "description": "A sasta lab for the things I want to build.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "module:build": "cd modules/sastaspace && cargo build --target wasm32-unknown-unknown --release",
    "module:test": "cd modules/sastaspace && cargo test",
    "module:publish:local": "spacetime publish --server local sastaspace --project-path modules/sastaspace -y",
    "module:publish:prod": "spacetime publish --server prod sastaspace --project-path modules/sastaspace -y",
    "bindings:generate": "spacetime generate --lang typescript --out-dir workers/stdb-bindings/src/generated --project-path modules/sastaspace",
    "typewars:build": "cd modules/typewars && cargo build --target wasm32-unknown-unknown --release",
    "typewars:test": "cd modules/typewars && cargo test",
    "typewars:publish:prod": "spacetime publish --server prod typewars -p modules/typewars -y",
    "typewars:bindings": "spacetime generate --lang typescript --out-dir workers/typewars-bindings/src/generated --module-path modules/typewars"
  }
}
