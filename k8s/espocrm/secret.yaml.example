# TEMPLATE — do not apply directly.
# Copy this file, replace passwords, then apply once on the server:
#   cp secret.yaml.example secret.yaml
#   # edit secret.yaml with real passwords
#   kubectl apply -f secret.yaml
#   rm secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: espocrm-env
  namespace: espocrm
type: Opaque
stringData:
  ESPOCRM_DATABASE_PASSWORD: "REPLACE_ME"
  MYSQL_ROOT_PASSWORD: "REPLACE_ME"
  ESPOCRM_ADMIN_PASSWORD: "REPLACE_ME"
