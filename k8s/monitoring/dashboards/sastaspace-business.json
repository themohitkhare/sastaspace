{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["sastaspace", "business"],
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "SastaSpace — Business Overview",
  "uid": "sastaspace-business",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Redesigns Today",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "increase(redesign_pipeline_total{status=\"success\"}[24h])",
        "legendFormat": "Redesigns",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success Rate (1h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green", "value": 80 }
          ]},
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "100 * rate(redesign_pipeline_total{status=\"success\"}[1h]) / (rate(redesign_pipeline_total[1h]) + 0.0001)",
        "legendFormat": "Success %",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sites Deployed",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sites_deployed_total",
        "legendFormat": "Sites",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Duration P50 (min)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2 },
            { "color": "red", "value": 5 }
          ]},
          "unit": "m",
          "decimals": 1
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "histogram_quantile(0.5, rate(redesign_pipeline_duration_seconds_bucket[1h])) / 60",
        "legendFormat": "P50",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Pipeline Errors (24h)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "increase(redesign_pipeline_total{status=\"error\"}[24h])",
        "legendFormat": "Errors",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Rate Limit Hits (24h)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 50 }
          ]},
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "increase(redesign_requests_total{status=\"rate_limited\"}[24h])",
        "legendFormat": "Rate Limited",
        "refId": "A"
      }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Pipeline Activity",
      "gridPos": { "x": 0, "y": 4, "w": 14, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "increase(redesign_pipeline_total{status=\"success\"}[$__rate_interval])",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "increase(redesign_pipeline_total{status=\"error\"}[$__rate_interval])",
          "legendFormat": "errors",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "increase(redesign_requests_total{status=\"rate_limited\"}[$__rate_interval])",
          "legendFormat": "rate limited",
          "refId": "C"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Pipeline Duration (seconds)",
      "gridPos": { "x": 14, "y": 4, "w": 10, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.5, rate(redesign_pipeline_duration_seconds_bucket[$__rate_interval]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(redesign_pipeline_duration_seconds_bucket[$__rate_interval]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Token Usage by Agent (tokens/s)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "rate(redesign_agent_tokens_total[$__rate_interval])",
        "legendFormat": "{{agent_name}} {{direction}}",
        "refId": "A"
      }]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Agent Duration P50 / P95 (seconds)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.5, sum by (agent_name, le) (rate(redesign_agent_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{agent_name}} p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (agent_name, le) (rate(redesign_agent_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{agent_name}} p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Guardrail Triggers",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "rate(redesign_guardrail_triggers_total[$__rate_interval])",
        "legendFormat": "{{guardrail_name}} / {{action}}",
        "refId": "A"
      }]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Pipeline Requests (all statuses)",
      "gridPos": { "x": 8, "y": 20, "w": 16, "h": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "increase(redesign_requests_total[$__rate_interval])",
        "legendFormat": "{{status}}",
        "refId": "A"
      }]
    },
    {
      "id": 40,
      "type": "stat",
      "title": "Redis Queue Depth",
      "gridPos": { "x": 0, "y": 26, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]},
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "redis_stream_length{stream=~\"redesign.*\"}",
        "legendFormat": "queue depth",
        "refId": "A"
      }]
    },
    {
      "id": 41,
      "type": "stat",
      "title": "Redis Connected Clients",
      "gridPos": { "x": 4, "y": 26, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "redis_connected_clients",
        "legendFormat": "clients",
        "refId": "A"
      }]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Redis Memory Used",
      "gridPos": { "x": 8, "y": 26, "w": 8, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "redis_memory_max_bytes",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "Redis Ops/sec",
      "gridPos": { "x": 16, "y": 26, "w": 8, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(redis_commands_processed_total[$__rate_interval])",
          "legendFormat": "commands/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(redis_keyspace_hits_total[$__rate_interval])",
          "legendFormat": "hits/s",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(redis_keyspace_misses_total[$__rate_interval])",
          "legendFormat": "misses/s",
          "refId": "C"
        }
      ]
    }
  ]
}
