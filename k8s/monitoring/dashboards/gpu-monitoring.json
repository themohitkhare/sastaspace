{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "GPU Utilization %",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Memory Used",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{gpu=~\"$gpu\"} / (DCGM_FI_DEV_FB_USED{gpu=~\"$gpu\"} + DCGM_FI_DEV_FB_FREE{gpu=~\"$gpu\"}) * 100",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Temperature",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "celsius",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Power Draw",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "watt",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Utilization Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Utilization",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "GPU Memory Over Time (MiB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Used",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_FB_USED{gpu=~\"$gpu\"} + DCGM_FI_DEV_FB_FREE{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "GPU Temperature Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Temp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "custom": {
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Power Draw Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Power",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "custom": { "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "SM Clock Speed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_SM_CLOCK{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} SM Clock",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "clockmhz",
          "min": 0,
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "PCIe Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_PCIE_TX_THROUGHPUT{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} TX",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_PCIE_RX_THROUGHPUT{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} RX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "KBs",
          "min": 0,
          "custom": { "fillOpacity": 15 }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gpu", "nvidia", "dcgm"],
  "templating": {
    "list": [
      {
        "name": "gpu",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(DCGM_FI_DEV_GPU_UTIL, gpu)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GPU Monitoring (NVIDIA DCGM)",
  "uid": "gpu-nvidia-dcgm",
  "version": 1
}
