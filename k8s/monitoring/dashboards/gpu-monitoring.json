{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "GPU Utilization %",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_utilization_percent{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "VRAM Used %",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_vram_used_bytes{gpu=~\"$gpu\"} / amd_gpu_vram_total_bytes{gpu=~\"$gpu\"} * 100",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Temperature",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_temperature_celsius{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 110,
          "unit": "celsius",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Power Draw",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_power_watts{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "watt",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 330 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Utilization Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_utilization_percent{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "VRAM Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_vram_used_bytes{gpu=~\"$gpu\"} / 1048576",
          "legendFormat": "GPU {{gpu}} Used (MiB)",
          "refId": "A"
        },
        {
          "expr": "amd_gpu_vram_total_bytes{gpu=~\"$gpu\"} / 1048576",
          "legendFormat": "GPU {{gpu}} Total (MiB)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "GPU Temperature Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_temperature_celsius{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "custom": {
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "GPU Power Draw Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_power_watts{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "custom": { "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "Shader Clock (SCLK)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_sclk_mhz{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} SCLK",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "clockmhz",
          "min": 0,
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Memory Clock (MCLK)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "amd_gpu_mclk_mhz{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} MCLK",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "clockmhz",
          "min": 0,
          "custom": { "fillOpacity": 10 }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gpu", "amd", "rocm"],
  "templating": {
    "list": [
      {
        "name": "gpu",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(amd_gpu_utilization_percent, gpu)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GPU Monitoring (AMD ROCm)",
  "uid": "gpu-amd-rocm",
  "version": 1
}
