{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Log Volume by Namespace",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"$namespace\"} [$__interval])) by (namespace)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Pod Logs",
      "type": "logs",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "{namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"} |= \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Error Logs (last 1h)",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "{namespace=~\"$namespace\"} |~ \"(?i)(error|exception|traceback|fatal|panic)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Worker Job Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 38 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "{namespace=\"sastaspace\", pod=~\"worker.*\"} |= \"JOB\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["logs", "loki"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values(namespace)",
        "current": { "text": "sastaspace", "value": "sastaspace" },
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({namespace=~\"$namespace\"}, pod)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({namespace=~\"$namespace\", pod=~\"$pod\"}, container)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "search",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Pod Logs (Loki)",
  "uid": "pod-logs-loki",
