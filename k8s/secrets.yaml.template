# k8s/secrets.yaml
#
# All secrets for the sastaspace namespace.
#
# FIRST-TIME SETUP:
#   1. Copy this file:  cp k8s/secrets.yaml.template k8s/secrets.yaml
#   2. Generate passwords:  openssl rand -base64 32
#   3. Replace ALL "CHANGE_ME*" placeholder values with real credentials
#   4. MONGODB_URL and REDIS_URL passwords must match their respective secrets
#   5. Apply:  kubectl apply -f k8s/secrets.yaml
#   6. NEVER commit k8s/secrets.yaml to git (only this .template file)
#
# NOTES:
#   - secrets.yaml is in .gitignore — only this template is tracked
#   - Backend pod loads sastaspace-env + sastaspace-db-auth via envFrom (see backend.yaml)
#   - Frontend pod loads sastaspace-frontend-env via envFrom (see frontend.yaml)
#   - NEXT_PUBLIC_TURNSTILE_SITE_KEY must also be passed as a --build-arg when building
#     the frontend Docker image (NEXT_PUBLIC_* vars are inlined at build time by Next.js
#     for client components; server components/API routes read them at runtime)
#
---
# MongoDB root credentials (referenced by mongodb.yaml deployment)
apiVersion: v1
kind: Secret
metadata:
  name: mongodb-auth
  namespace: sastaspace
type: Opaque
stringData:
  MONGO_USER: "sastaspace"
  MONGO_PASSWORD: "CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"
---
# Redis password (referenced by redis.yaml deployment)
apiVersion: v1
kind: Secret
metadata:
  name: redis-auth
  namespace: sastaspace
type: Opaque
stringData:
  REDIS_PASSWORD: "CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"
---
# Authenticated connection URLs (referenced by backend + worker pods)
apiVersion: v1
kind: Secret
metadata:
  name: sastaspace-db-auth
  namespace: sastaspace
type: Opaque
stringData:
  MONGODB_URL: "mongodb://sastaspace:CHANGE_ME_MATCH_MONGO_PASSWORD@mongodb:27017/sastaspace?authSource=admin"
  REDIS_URL: "redis://:CHANGE_ME_MATCH_REDIS_PASSWORD@redis:6379"
---
# Application secrets for the backend pod (loaded via envFrom secretRef in backend.yaml)
# Contains API keys, tokens, and credentials used by the FastAPI server.
apiVersion: v1
kind: Secret
metadata:
  name: sastaspace-env
  namespace: sastaspace
type: Opaque
stringData:
  # Admin endpoint authentication (for /admin/* routes)
  ADMIN_KEY: "CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"

  # Anthropic API key — consumed by claude-code-api gateway for AI inference
  ANTHROPIC_API_KEY: "CHANGE_ME_sk-ant-api03-..."

  # Gemini API key — alternative AI provider (optional, leave empty to disable)
  GEMINI_API_KEY: ""

  # Vikunja integration — task-based lead tracking
  # Get the API token from Vikunja Settings > API Tokens
  VIKUNJA_URL: "http://vikunja.vikunja.svc:3456"
  VIKUNJA_TOKEN: "CHANGE_ME_GENERATE_VIKUNJA_API_TOKEN"
  VIKUNJA_PROJECT_ID: "2"
---
# Application secrets for the frontend pod (loaded via envFrom secretRef in frontend.yaml)
# Contains server-side secrets used by Next.js API routes (e.g., contact form).
# NEXT_PUBLIC_* vars here are available at runtime in server components and API routes,
# but for client-side components they must ALSO be passed as --build-arg at image build.
apiVersion: v1
kind: Secret
metadata:
  name: sastaspace-frontend-env
  namespace: sastaspace
type: Opaque
stringData:
  # Resend email delivery — used by POST /api/contact to send inquiry emails
  RESEND_API_KEY: "CHANGE_ME_re_..."

  # Contact form destination — all inquiry emails are sent to this address
  OWNER_EMAIL: "CHANGE_ME_you@example.com"

  # Cloudflare Turnstile — bot protection on the contact form
  # Get keys from: https://dash.cloudflare.com/ > Turnstile
  # NOTE: NEXT_PUBLIC_TURNSTILE_SITE_KEY is used in a client component (contact-form.tsx),
  # so it must also be passed as --build-arg to the frontend Docker image build.
  NEXT_PUBLIC_TURNSTILE_SITE_KEY: "CHANGE_ME_0x..."
  TURNSTILE_SECRET_KEY: "CHANGE_ME_0x..."

  # Set to "false" to disable Turnstile verification (useful for staging)
  NEXT_PUBLIC_ENABLE_TURNSTILE: "true"
